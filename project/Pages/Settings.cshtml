@page
@model SettingsModel
@{
    Layout = null;
    ViewData["Title"] = "إعدادات مستهدفات مؤشرات الأداء - شركة رواحل المشاعر";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <!-- Tailwind CSS للتنسيق العصري والمودرن -->
    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@4"></script>
    <!-- Google Fonts - IBM Plex Sans Arabic, Tajawal & Cairo الخط العربي المعتمد احترافياً و Outfit للإنجليزية -->
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;650;700&family=Tajawal:wght@300;400;500;700;850;900&family=Cairo:wght@300;400;600;700;900&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <!-- FontAwesome للأيقونات -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- AOS Library للأنيميشن الاحترافي عند التمرير وسكرول الصفحة -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    
    <style>
        /* Load IBM Plex Sans Arabic as primary, Tajawal/Cairo as fallback */
        body, button, input, select, textarea, span, h1, h2, h3, h4, h5, h6, p, div, a {
            font-family: 'Tajawal', sans-serif;
        }

        html[dir="ltr"] body, html[dir="ltr"] button, html[dir="ltr"] input, html[dir="ltr"] select, html[dir="ltr"] textarea, html[dir="ltr"] span, html[dir="ltr"] h1, html[dir="ltr"] h2, html[dir="ltr"] h3, html[dir="ltr"] h4, html[dir="ltr"] h5, html[dir="ltr"] h6, html[dir="ltr"] p, html[dir="ltr"] div, html[dir="ltr"] a {
            font-family: 'Outfit', sans-serif;
        }

        body {
            background-image: linear-gradient(rgba(250, 249, 246, 0.98), rgba(250, 249, 246, 0.98)), url('https://www.rawahel.com.sa/wp-content/themes/tl4s-raoaa_rawahel/images/slider10.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
            color: #0f172a;
        }

        .bg-sidebar { background-color: #ffffff; }
        .bg-sidebar-active { 
            background: linear-gradient(135deg, #ca9b29 0%, #a87919 100%); 
            color: #ffffff !important; 
            box-shadow: 0 4px 15px rgba(202, 155, 41, 0.3); 
        }
        
        .text-gold-brand { color: #ca9b29; }
        .bg-gold-brand { background-color: #ca9b29; }

        /* glassmorphism components with glowing effects */
        .glass-card {
            background-color: #ffffff;
            border: 1px solid rgba(202, 155, 41, 0.25);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.04);
            transition: all 0.3s ease-in-out;
            color: #334155;
        }
        .glass-card:hover {
            transform: translateY(-3px);
            border-color: rgba(202, 155, 41, 0.5);
            box-shadow: 0 10px 30px rgba(202, 155, 41, 0.12);
        }

        /* Scale settings cards */
        #kpi-settings-container .glass-card {
            min-height: 15rem !important;
            height: auto !important;
            padding: 2rem !important;
            border-radius: 1.5rem !important;
        }
        #kpi-settings-container .glass-card h4 {
            font-size: 1rem !important; /* text-base, was text-xs */
            font-weight: 950 !important;
        }
        #kpi-settings-container .glass-card p {
            font-size: 0.825rem !important; /* text-xs/sm, was text-[9px] */
            font-weight: 500 !important;
            line-height: 1.5 !important;
        }
        #kpi-settings-container .glass-card label {
            font-size: 0.825rem !important; /* text-xs, was text-[9px] */
            font-weight: 850 !important;
        }
        #kpi-settings-container .glass-card input[type="number"] {
            font-size: 0.95rem !important; /* text-sm, was text-xs */
            padding: 0.625rem !important;
            border-radius: 0.75rem !important;
        }
        #kpi-settings-container .glass-card .text-\[8px\] {
            font-size: 0.775rem !important; /* text-xs, was text-[8px] */
            padding: 0.625rem !important;
            border-radius: 0.75rem !important;
        }
        #kpi-settings-container .glass-card span[id^="preview-badge-"] {
            font-size: 0.8rem !important; /* text-xs */
            padding: 0.35rem 0.75rem !important;
        }
        
        /* Sidebar Text Scaling */
        aside nav a {
            font-size: 0.875rem !important; /* text-sm */
            padding-top: 0.75rem !important;
            padding-bottom: 0.75rem !important;
        }
        aside nav .pt-3 {
            font-size: 0.75rem !important; /* text-xs */
        }
        aside .text-\[9px\] {
            font-size: 0.75rem !important;
        }
        
        /* custom scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(240, 240, 240, 0.8);
        }
        ::-webkit-scrollbar-thumb {
            background: #ca9b29;
            border-radius: 3px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #e5b842;
        }

        /* custom range slider */
        input[type=range] {
            accent-color: #ca9b29;
        }

        /* Premium Sidebar Navbar Navigation */
        aside a {
            font-size: 0.9rem !important; /* Larger text size, about 14.4px */
            font-weight: 700 !important; /* Bold */
            padding: 0.75rem 1rem !important; /* Spacing */
            margin-bottom: 0.35rem !important;
            display: flex !important;
            align-items: center !important;
            gap: 0.85rem !important;
            border-radius: 0.75rem !important; /* Rounded corners */
            color: #334155 !important; /* Slate 700 */
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
        }
        aside a i {
            color: #ca9b29 !important; /* Gold icons in inactive state */
            font-size: 1.1rem !important; /* Larger icons for scanning */
            width: 1.5rem !important;
            text-align: center !important;
            transition: color 0.25s ease !important;
        }
        aside a:hover {
            background-color: #fafaf9 !important; /* Soft warm grey background */
            color: #ca9b29 !important; /* Hover text in gold */
        }
        aside a:hover i {
            color: #ca9b29 !important; /* Keep hover icon gold */
        }
        
        /* Active Link State */
        aside a.bg-sidebar-active {
            background: linear-gradient(135deg, #ca9b29 0%, #a87919 100%) !important;
            color: #ffffff !important;
            box-shadow: 0 4px 15px rgba(202, 155, 41, 0.3) !important;
            font-weight: 850 !important;
        }
        aside a.bg-sidebar-active i {
            color: #ffffff !important; /* Force white icon when active */
        }
    </style>
</head>
<body class="antialiased selection:bg-[#ca9b29] selection:text-white">

    <div class="flex min-h-screen">
        <!-- ================= القائمة الجانبية (Sidebar) ================= -->
        <aside class="w-72 bg-sidebar text-slate-600 p-5 flex flex-col justify-between hidden lg:flex border-l-2 border-[#ca9b29]/40 shrink-0 shadow-sm">
            <div>
                <!-- الشعار المطور المعتمد لشركة رواحل -->
                <div class="flex flex-col items-center text-center mt-2 mb-6 bg-white border border-[#ca9b29]/30 p-4 rounded-xl shadow-xs">
                    <img src="https://www.rawahel.com.sa/wp-content/themes/tl4s-raoaa_rawahel/images/logo.png" alt="شركة رواحل المشاعر" class="w-24 h-auto object-contain mb-1 filter drop-shadow-sm">
                    <h2 class="text-slate-800 text-xs font-black tracking-wide mt-1">شركة رواحل المشاعر</h2>
                    <span class="text-[8px] text-[#ca9b29] block tracking-wider font-bold mt-0.5">RAWAHEL AL MASHAER CO.</span>
                </div>

                <nav class="space-y-1.5">
                    <a href="/Index">
                        <i class="fa-solid fa-table-columns"></i>
                        <span>لوحة التحكم والأعلام</span>
                    </a>
                    
                    <a href="/Index#finance-group">
                        <i class="fa-solid fa-wallet"></i>
                        <span>الإدارة المالية</span>
                    </a>
                    
                    <a href="/Index#commercial-group">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>الإدارة التجارية</span>
                    </a>
                    
                    <a href="/Index#ops-fleet-group">
                        <i class="fa-solid fa-bus"></i>
                        <span>العمليات والأسطول</span>
                    </a>

                    <a href="/Index#support-group">
                        <i class="fa-solid fa-handshake-angle"></i>
                        <span>إدارات المساندة و HSE</span>
                    </a>
                </nav>
            </div>

            <div class="space-y-1 border-t border-slate-100 pt-3">
                @if (Model.IsSuperAdmin)
                {
                    <a href="/Users">
                        <i class="fa-solid fa-users-cog"></i>
                        <span>إدارة المستخدمين</span>
                    </a>
                }
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                {
                    <a href="/Settings" class="bg-sidebar-active">
                        <i class="fa-solid fa-gear"></i>
                        <span>إعدادات المستهدفات</span>
                    </a>
                }
                <div class="text-[9px] text-slate-400 text-center pt-2 font-mono">نظام رواحل القياسي المعتمد © 2026</div>
            </div>
        </aside>

        <!-- ================= المحتوى الرئيسي ================= -->
        <main class="flex-1 p-6 lg:p-10 xl:p-12 overflow-y-auto max-w-[1600px] mx-auto w-full">
            
            <!-- الهيدر العلوي -->
            <header class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8 bg-white p-5 rounded-2xl border border-[#ca9b29]/20 shadow-xs relative overflow-hidden">
                <div class="text-right">
                    <h1 class="text-xl sm:text-2xl font-black text-slate-900 tracking-tight flex items-center gap-2">
                        <span class="w-2 h-6 bg-gradient-to-b from-[#ca9b29] to-[#a87919] rounded-full inline-block"></span>
                        <span class="bg-gradient-to-r from-slate-900 via-slate-800 to-[#ca9b29] bg-clip-text text-transparent">إعدادات أهداف ونطاقات المؤشرات (KPIs Ranges)</span>
                    </h1>
                    <p class="text-xs text-[#ca9b29] mt-1.5 font-bold">تحديد مستهدفات ونطاقات التقييم (ممتاز / جيد / ضعيف) لتحديث لوحة التحكم والأعلام dynamically.</p>
                </div>
                
                <div class="flex items-center gap-3 w-full sm:w-auto justify-end">
                    <a href="/Index" class="bg-gradient-to-r from-[#ca9b29] to-[#a87919] text-white px-5 py-2.5 rounded-xl text-xs font-black flex items-center gap-2 shadow-sm hover:opacity-95 transition-all active:scale-95 cursor-pointer">
                        <i class="fa-solid fa-arrow-right"></i>
                        <span>العودة للوحة الأداء</span>
                    </a>

                    <!-- زر تسجيل الخروج -->
                    <form method="post" action="/Account/Logout" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="bg-slate-100 hover:bg-slate-200 text-rose-600 border border-slate-200 px-4 py-2.5 rounded-xl text-xs font-black flex items-center gap-2 transition-all cursor-pointer shadow-xs">
                            <i class="fa-solid fa-sign-out-alt"></i>
                            <span>خروج</span>
                        </button>
                    </form>

                    <!-- الملف الشخصي للمستخدِم -->
                    <div onclick="openProfileModal()" class="flex items-center gap-3 border-s border-slate-200 ps-4 cursor-pointer hover:opacity-85 transition-opacity">
                        <div class="text-start">
                            <div class="flex items-center gap-1.5 justify-start">
                                <i class="fa-solid fa-circle-info text-[10px] text-[#ca9b29]"></i>
                                <h4 class="text-xs font-black text-slate-800">@Model.UserArabicDisplayName</h4>
                            </div>
                            <span class="text-[9px] bg-[#ca9b29]/10 border border-[#ca9b29]/30 text-[#ca9b29] px-2.5 py-0.5 rounded-md font-black mt-1 inline-block">
                                @(User.IsInRole("SuperAdmin") ? "مدير عام" : User.IsInRole("Admin") ? "مسؤول نظام" : User.IsInRole("Manager") ? "مدير قطاع" : "مستخدم قطاع")
                            </span>
                        </div>
                        <div class="w-10 h-10 rounded-full border border-[#ca9b29]/40 shadow-xs overflow-hidden bg-white flex items-center justify-center text-[#ca9b29] font-black text-xs">
                            @(string.IsNullOrEmpty(Model.UserArabicDisplayName) ? "?" : Model.UserArabicDisplayName[0].ToString())
                        </div>
                    </div>
                </div>
            </header>

            <!-- تبويبات الفئات بالتصميم الزجاجي المبتكر -->
            <section class="mb-6" data-aos="fade-up">
                <div class="bg-white p-2 rounded-2xl border border-slate-200 shadow-xs flex flex-wrap gap-2">
                    <button onclick="switchCategory('finance')" id="tab-finance" class="tab-btn px-4 py-2.5 rounded-xl text-xs font-black flex items-center gap-2 transition-all cursor-pointer">
                        <i class="fa-solid fa-wallet text-sm"></i>
                        <span>الإدارة المالية</span>
                    </button>
                    <button onclick="switchCategory('commercial')" id="tab-commercial" class="tab-btn px-4 py-2.5 rounded-xl text-xs font-black flex items-center gap-2 transition-all cursor-pointer">
                        <i class="fa-solid fa-chart-line text-sm"></i>
                        <span>الإدارة التجارية والعملاء</span>
                    </button>
                    <button onclick="switchCategory('ops')" id="tab-ops" class="tab-btn px-4 py-2.5 rounded-xl text-xs font-black flex items-center gap-2 transition-all cursor-pointer">
                        <i class="fa-solid fa-bus text-sm"></i>
                        <span>العمليات وأسطول الحافلات</span>
                    </button>
                    <button onclick="switchCategory('support')" id="tab-support" class="tab-btn px-4 py-2.5 rounded-xl text-xs font-black flex items-center gap-2 transition-all cursor-pointer">
                        <i class="fa-solid fa-laptop-code text-sm"></i>
                        <span>الموارد البشرية والتقنية</span>
                    </button>
                    <button onclick="switchCategory('hse')" id="tab-hse" class="tab-btn px-4 py-2.5 rounded-xl text-xs font-black flex items-center gap-2 transition-all cursor-pointer">
                        <i class="fa-solid fa-shield-halved text-sm"></i>
                        <span>HSE والامتثال والتدقيق</span>
                    </button>
                    <button onclick="switchCategory('strategy')" id="tab-strategy" class="tab-btn px-4 py-2.5 rounded-xl text-xs font-black flex items-center gap-2 transition-all cursor-pointer">
                        <i class="fa-solid fa-bullseye text-sm"></i>
                        <span>الاستراتيجية والمشاريع PMO</span>
                    </button>
                </div>
            </section>

            <!-- محتوى المؤشرات لكل قسم -->
            <section id="kpi-settings-container" class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8" data-aos="fade-up">
                <!-- سيتم ملؤه ديناميكياً بواسطة الجافاسكريبت -->
            </section>

            <!-- شريط العمليات السفلي الثابت (حفظ وإلغاء وتصفير) -->
            <footer class="flex flex-col sm:flex-row justify-between items-center gap-4 bg-white p-5 rounded-2xl border border-slate-200 shadow-sm" data-aos="fade-up">
                <div class="text-right">
                    <h3 class="text-sm font-black text-slate-800 flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                        حفظ ومزامنة نطاقات ومستهدفات الأداء
                    </h3>
                    <p class="text-[10px] text-slate-500 font-bold mt-1">سيتم تطبيق التحديثات على الأعلام الملونة وأشرطة التقدم والتقارير التنفيذية فور الحفظ.</p>
                </div>
                <div class="flex flex-wrap gap-3">
                    <button onclick="resetToDefaults()" class="bg-slate-100 hover:bg-slate-200 text-slate-700 px-5 py-2.5 rounded-xl text-xs font-black flex items-center gap-2 transition-all cursor-pointer border border-slate-200">
                        <i class="fa-solid fa-rotate-left"></i>
                        <span>إعادة ضبط المستهدفات</span>
                    </button>
                    <button onclick="saveTargets()" class="bg-gradient-to-r from-[#ca9b29] to-[#a87919] text-white px-6 py-2.5 rounded-xl text-xs font-black flex items-center gap-2 shadow-xs transition-all cursor-pointer hover:opacity-95">
                        <i class="fa-solid fa-floppy-disk"></i>
                        <span>حفظ ومزامنة النطاقات</span>
                    </button>
                </div>
            </footer>

        </main>
    </div>

    <!-- مودال نجاح الحفظ المنبثق -->
    <div id="successModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
        <div id="successModalOverlay" class="absolute inset-0 bg-black/60 backdrop-blur-xs transition-opacity duration-300 opacity-0"></div>
        <div id="successModalBox" class="relative bg-white rounded-3xl p-8 border border-[#ca9b29] shadow-2xl max-w-sm w-full mx-4 text-center transform scale-90 opacity-0 transition-all duration-300">
            <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4 text-emerald-600 text-3xl">
                <i class="fa-solid fa-circle-check animate-bounce"></i>
            </div>
            <h3 class="text-lg font-black text-slate-800 mb-2">تم الحفظ بنجاح!</h3>
            <p class="text-xs text-slate-600 font-bold mb-6">تم تحديث الأهداف والنطاقات للـ 22 مؤشراً، ومزامنتها مع شاشات الأداء والرسوم البيانية.</p>
            <button onclick="closeSuccessModal()" class="w-full bg-gradient-to-r from-[#ca9b29] to-[#a87919] text-white py-3 rounded-xl text-xs font-black shadow-md transition-all active:scale-95 cursor-pointer">
                حسنًا، اذهب للوحة الأداء
            </button>
        </div>
    </div>

    <!-- ================= لوحة معلومات الملف الشخصي المنبثقة ================= -->
    <div id="profileModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 hidden">
        <div id="profileModalOverlay" class="fixed inset-0 bg-black/60 backdrop-blur-xs opacity-0 transition-opacity duration-300" onclick="closeProfileModal()"></div>
        <div id="profileModalBox" class="bg-white w-full max-w-xs rounded-3xl border border-[#ca9b29]/40 shadow-2xl overflow-hidden transform scale-90 opacity-0 transition-all duration-300 flex flex-col p-6 z-10 text-center text-slate-800">
            <button onclick="closeProfileModal()" class="absolute top-4 left-4 w-6 h-6 rounded-full bg-slate-100 hover:bg-slate-200 text-slate-800 flex items-center justify-center transition-colors border border-slate-200">
                <i class="fa-solid fa-xmark text-xs"></i>
            </button>
            <div class="w-16 h-16 rounded-full border-2 border-[#ca9b29] bg-[#faf9f6] flex items-center justify-center text-[#ca9b29] font-black text-lg mx-auto shadow-sm mb-3">
                @(string.IsNullOrEmpty(Model.UserArabicDisplayName) ? "?" : Model.UserArabicDisplayName[0].ToString())
            </div>
            <h4 class="text-sm font-black text-slate-900 text-center mb-1">@Model.UserArabicDisplayName</h4>
            <span class="text-[9px] bg-[#ca9b29]/10 border border-[#ca9b29]/30 text-[#ca9b29] px-3 py-0.5 rounded-full font-black mx-auto inline-block mb-4">
                @(User.IsInRole("SuperAdmin") ? "مدير عام" : User.IsInRole("Admin") ? "مسؤول نظام" : User.IsInRole("Manager") ? "مدير قطاع" : "مستخدم قطاع")
            </span>
            <div class="border-t border-slate-100 pt-4 space-y-2.5 text-[10px] text-slate-600 font-bold text-start">
                <div class="flex justify-between">
                    <span class="text-slate-500">البريد الإلكتروني:</span>
                    <span class="font-mono text-slate-700">@User.Identity?.Name</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-slate-500">الصلاحيات البرمجية:</span>
                    <span class="text-[#ca9b29] font-black">
                        @(User.IsInRole("SuperAdmin") ? "إدارة كاملة للنظام (SuperAdmin)" : User.IsInRole("Admin") ? "مسؤول نظام (Admin)" : User.IsInRole("Manager") ? "مدير قطاع (Manager)" : "مستخدم قطاع (User)")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- تفعيل سكريبت AOS -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        try {
            AOS.init({ duration: 800, once: true });
        } catch (e) {
            console.warn("AOS library failed to initialize");
        }

        // 1. تعريف 22 مؤشراً للأداء في شركة رواحل بالكامل
        const kpiDefinition = {
            'finance': {
                title: 'الإدارة المالية',
                kpis: [
                    { key: 'rev-growth', name: 'إجمالي الإيرادات ومعدل النمو', unit: 'M ر.س', min: 100, max: 200, step: 0.5, default: 150, defaultExc: 142.5, defaultGood: 112.5, desc: 'إجمالي إيرادات شركة رواحل المحققة من كافة عقود التشغيل.' },
                    { key: 'ebitda', name: 'هامش EBITDA التشغيلي', unit: '%', min: 10, max: 60, step: 0.5, default: 35, defaultExc: 33.25, defaultGood: 26.25, desc: 'هامش الربحية التشغيلية قبل احتساب الفوائد والإهلاك والضرائب.' },
                    { key: 'cashflow', name: 'التدفق النقدي التشغيلي', unit: 'M', min: 20, max: 100, step: 0.5, default: 50, defaultExc: 47.5, defaultGood: 37.5, desc: 'السيولة النقدية المتدفقة من الأنشطة التشغيلية والتحصيل.' },
                    { key: 'roa', name: 'العائد على الأصول ROA', unit: '%', min: 3, max: 25, step: 0.1, default: 12, defaultExc: 11.4, defaultGood: 9.0, desc: 'كفاءة تشغيل حافلات وورش أصول شركة رواحل لتحقيق الربح.' }
                ]
            },
            'commercial': {
                title: 'الإدارة التجارية والعملاء',
                kpis: [
                    { key: 'cust-ret', name: 'نسبة الاحتفاظ بالعملاء', unit: '%', min: 50, max: 100, step: 0.5, default: 85, defaultExc: 80.75, defaultGood: 63.75, desc: 'معدل بقاء وتجديد العقود مع شركات السياحة وبعثات الحج الخارجية.' },
                    { key: 'nps', name: 'صافي نقاط التوصية NPS (رضا العملاء)', unit: 'نقطة', min: 30, max: 100, step: 1, default: 70, defaultExc: 66.5, defaultGood: 52.5, desc: 'نقاط رضا ضيوف الرحمن والركاب عن نظافة وراحة الحافلات وحل المشاكل.' },
                    { key: 'new-contracts', name: 'عدد العقود الاستراتيجية الجديدة', unit: 'عقد', min: 2, max: 30, step: 1, default: 15, defaultExc: 14.25, defaultGood: 11.25, desc: 'العقود الاستراتيجية الجديدة المبرمة مع وكلاء السياحة والنقل العام.' }
                ]
            },
            'ops': {
                title: 'العمليات وأسطول الحافلات',
                kpis: [
                    { key: 'ops-plan', name: 'الالتزام بالخطة التشغيلية', unit: '%', min: 70, max: 100, step: 0.5, default: 90, defaultExc: 85.5, defaultGood: 67.5, desc: 'نسبة مطابقة مسارات وجداول رحلات الحافلات بالخطة المعتمدة.' },
                    { key: 'fleet-ready', name: 'نسبة جاهزية أسطول الحافلات للتشغيل', unit: '%', min: 80, max: 100, step: 0.5, default: 95, defaultExc: 90.25, defaultGood: 71.25, desc: 'معدل الحافلات الجاهزة للحركة الفورية من إجمالي 1,240 حافلة.' },
                    { key: 'fleet-util', name: 'نسبة استغلال أسطول مقاعد الحافلات', unit: '%', min: 50, max: 100, step: 0.5, default: 85, defaultExc: 80.75, defaultGood: 63.75, desc: 'كفاءة ملء المقاعد للحافلات في رحلات الحج والعمرة والتعاقدات.' }
                ]
            },
            'support': {
                title: 'الموارد البشرية والتقنية والمسانده',
                kpis: [
                    { key: 'hr-ret', name: 'معدل الاحتفاظ بالموظفين الكوادر', unit: '%', min: 60, max: 100, step: 0.5, default: 90, defaultExc: 85.5, defaultGood: 67.5, desc: 'بقائ سائقي الحافلات وفنيي ورش صيانة المركبات في الخدمة.' },
                    { key: 'it-autom', name: 'تنفيذ مشاريع التحول الرقمي وأتمتة الورش', unit: '%', min: 40, max: 100, step: 0.5, default: 80, defaultExc: 76.0, defaultGood: 60.0, desc: 'معدل التحول الرقمي للمهام ونظام الجدولة الفورية وتتبع GPS.' },
                    { key: 'critical-succession', name: 'خطط الإحلال والتعاقب للوظائف الحرجة', unit: '%', min: 50, max: 100, step: 0.5, default: 80, defaultExc: 76.0, defaultGood: 60.0, desc: 'نسبة الوظائف الحيوية والقيادية المغطاة بكوادر بديلة جاهزة.' },
                    { key: 'saudization', name: 'نسبة التوطين والسعوده بالشركة', unit: '%', min: 10, max: 70, step: 0.5, default: 35, defaultExc: 33.25, defaultGood: 26.25, desc: 'نسبة الكوادر الوطنية السعودية المسجلة في نطاقات وزارة الموارد البشرية.' }
                ]
            },
            'hse': {
                title: 'HSE والسلامة والامتثال',
                kpis: [
                    { key: 'hse-ltifr', name: 'معدل حوادث العمل LTIFR', unit: 'إصابة/مليون ساعة', min: 0.2, max: 5.0, step: 0.1, default: 1.5, defaultExc: 1.5, defaultGood: 2.0, desc: 'معدل الإصابات المهنية المانعة عن العمل لكل مليون ساعة (مؤشر عكسي: الأقل هو الأفضل).', isInverse: true },
                    { key: 'hse-accidents', name: 'حوادث جسيمة للحافلات بالطرق', unit: 'حادث', min: 0, max: 5, step: 1, default: 0, defaultExc: 0, defaultGood: 1, desc: 'عدد حوادث التصادم أو الانقلاب الجسيمة المسجلة للحافلات (مؤشر عكسي).', isInverse: true },
                    { key: 'audit-comp', name: 'نسبة الامتثال للسياسات والتراخيص', unit: '%', min: 70, max: 100, step: 0.5, default: 95, defaultExc: 90.25, defaultGood: 71.25, desc: 'الالتزام بمتطلبات نقابة السيارات، الفحص الفني، والتراخيص المخططة.' }
                ]
            },
            'strategy': {
                title: 'الاستراتيجية والمشاريع PMO والحوكمة',
                kpis: [
                    { key: 'strat-goals', name: 'تحقيق أهداف الاستراتيجية والتوسع', unit: '%', min: 50, max: 100, step: 0.5, default: 85, defaultExc: 80.75, defaultGood: 63.75, desc: 'نسبة تحقيق أهداف الخطة الخمسية للتوسع الجغرافي وزيادة الحصة السوقية.' },
                    { key: 'strat-init', name: 'معدل إنجاز مبادرات مكتب PMO', unit: '%', min: 50, max: 100, step: 0.5, default: 90, defaultExc: 85.5, defaultGood: 67.5, desc: 'نسبة إنجاز مشاريع التحول المؤسسي وتجهيز البنى التحتية.' },
                    { key: 'risk-handling', name: 'نسبة معالجة المخاطر المؤسسية', unit: '%', min: 60, max: 100, step: 0.5, default: 90, defaultExc: 85.5, defaultGood: 67.5, desc: 'تنفيذ خطط الاستجابة للمخاطر المالية والتشغيلية المعتمدة.' },
                    { key: 'gov-maturity', name: 'مستوى تطبيق حوكمة الشركات', unit: '%', min: 65, max: 100, step: 0.5, default: 95, defaultExc: 90.25, defaultGood: 71.25, desc: 'مستوى نضج الحوكمة والشفافية وتوزيع صلاحيات اللجان الإدارية.' },
                    { key: 'strat-goals-achieve', name: 'نسبة تحقيق الأهداف الاستراتيجية الموحدة', unit: '%', min: 50, max: 100, step: 0.5, default: 85, defaultExc: 80.75, defaultGood: 63.75, desc: 'المعدل الكلي لإنجاز أهداف الهيئة الإدارية والتطويرية للشركة.' }
                ]
            }
        };

        const actualValues = {
            'rev-growth': 142.5, 
            'ebitda': 34.5,
            'cashflow': 48.0,
            'roa': 10.5,
            'cust-ret': 88.0,
            'nps': 55.0,
            'new-contracts': 12,
            'ops-plan': 92.5,
            'fleet-ready': 92.0,
            'fleet-util': 80.0,
            'hr-ret': 89.0,
            'it-autom': 78.0,
            'critical-succession': 82.0,
            'saudization': 38.5,
            'hse-ltifr': 1.2,
            'hse-accidents': 0,
            'audit-comp': 91.0,
            'strat-goals': 82.0,
            'strat-init': 85.0,
            'risk-handling': 88.0,
            'gov-maturity': 90.0,
            'strat-goals-achieve': 85.0
        };

        let currentActiveCategory = 'finance';
        let currentSettings = {};

        const defaultSettings = {
            'rev-growth': { target: 150, excellentMin: 142.5, goodMin: 112.5 },
            'ebitda': { target: 35, excellentMin: 33.25, goodMin: 26.25 },
            'cashflow': { target: 50, excellentMin: 47.5, goodMin: 37.5 },
            'roa': { target: 12, excellentMin: 11.4, goodMin: 9.0 },
            'cust-ret': { target: 85, excellentMin: 80.75, goodMin: 63.75 },
            'nps': { target: 70, excellentMin: 66.5, goodMin: 52.5 },
            'new-contracts': { target: 15, excellentMin: 14.25, goodMin: 11.25 },
            'ops-plan': { target: 90, excellentMin: 85.5, goodMin: 67.5 },
            'fleet-ready': { target: 95, excellentMin: 90.25, goodMin: 71.25 },
            'fleet-util': { target: 85, excellentMin: 80.75, goodMin: 63.75 },
            'hr-ret': { target: 90, excellentMin: 85.5, goodMin: 67.5 },
            'it-autom': { target: 80, excellentMin: 76.0, goodMin: 60.0 },
            'critical-succession': { target: 80, excellentMin: 76.0, goodMin: 60.0 },
            'saudization': { target: 35, excellentMin: 33.25, goodMin: 26.25 },
            'hse-ltifr': { target: 1.5, excellentMax: 1.5, goodMax: 2.0 },
            'hse-accidents': { target: 0, excellentMax: 0, goodMax: 1 },
            'audit-comp': { target: 95, excellentMin: 90.25, goodMin: 71.25 },
            'strat-goals': { target: 85, excellentMin: 80.75, goodMin: 63.75 },
            'strat-init': { target: 90, excellentMin: 85.5, goodMin: 67.5 },
            'risk-handling': { target: 90, excellentMin: 85.5, goodMin: 67.5 },
            'gov-maturity': { target: 95, excellentMin: 90.25, goodMin: 71.25 },
            'strat-goals-achieve': { target: 85, excellentMin: 80.75, goodMin: 63.75 }
        };

        function initSettings() {
            const saved = localStorage.getItem('kpi_settings');
            if (saved) {
                try {
                    currentSettings = JSON.parse(saved);
                } catch (e) {
                    console.error(e);
                    currentSettings = JSON.parse(JSON.stringify(defaultSettings));
                }
            } else {
                currentSettings = JSON.parse(JSON.stringify(defaultSettings));
            }
            
            Object.keys(defaultSettings).forEach(key => {
                if (!currentSettings[key]) {
                    currentSettings[key] = { ...defaultSettings[key] };
                }
            });
        }

        function calculateFlag(key, actual, isInverse) {
            const config = currentSettings[key];
            if (!config) return { label: '🟢 ممتاز', badgeClass: 'bg-emerald-100 text-emerald-700 border border-emerald-200' };
            
            if (isInverse) {
                if (actual <= config.excellentMax) {
                    return { label: '🟢 ممتاز', badgeClass: 'bg-emerald-100 text-emerald-700 border border-emerald-200' };
                } else if (actual <= config.goodMax) {
                    return { label: '🟡 جيد', badgeClass: 'bg-amber-100 text-amber-700 border border-amber-200' };
                } else {
                    return { label: '🔴 ضعيف', badgeClass: 'bg-rose-100 text-rose-700 border border-rose-200' };
                }
            } else {
                if (actual >= config.excellentMin) {
                    return { label: '🟢 ممتاز', badgeClass: 'bg-emerald-100 text-emerald-700 border border-emerald-200' };
                } else if (actual >= config.goodMin) {
                    return { label: '🟡 جيد', badgeClass: 'bg-amber-100 text-amber-700 border border-amber-200' };
                } else {
                    return { label: '🔴 ضعيف', badgeClass: 'bg-rose-100 text-rose-700 border border-rose-200' };
                }
            }
        }

        function switchCategory(catKey) {
            currentActiveCategory = catKey;
            
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('bg-sidebar-active', 'text-white');
                btn.classList.add('bg-white', 'text-slate-700', 'border', 'border-slate-200');
            });
            
            const activeBtn = document.getElementById(`tab-${catKey}`);
            if (activeBtn) {
                activeBtn.classList.remove('bg-white', 'text-slate-700', 'border', 'border-slate-200');
                activeBtn.classList.add('bg-sidebar-active');
            }

            renderKpis();
        }

        function renderKpis() {
            const container = document.getElementById('kpi-settings-container');
            if (!container) return;

            container.innerHTML = '';
            const category = kpiDefinition[currentActiveCategory];

            category.kpis.forEach(kpi => {
                const config = currentSettings[kpi.key];
                const actualVal = actualValues[kpi.key];
                const flag = calculateFlag(kpi.key, actualVal, kpi.isInverse);

                const excellentVal = kpi.isInverse ? config.excellentMax : config.excellentMin;
                const goodVal = kpi.isInverse ? config.goodMax : config.goodMin;

                const kpiHtml = `
                    <div class="glass-card p-5 rounded-2xl flex flex-col justify-between relative overflow-hidden text-slate-700" data-aos="fade-up">
                        <div class="absolute -top-10 -left-10 w-24 h-24 bg-[#ca9b29]/5 rounded-full blur-xl"></div>
                        
                        <div>
                            <div class="flex justify-between items-start gap-2 mb-3 border-b border-slate-100 pb-3">
                                <div class="text-start">
                                    <h4 class="text-xs font-black text-slate-800">${kpi.name}</h4>
                                    <p class="text-[9px] text-slate-500 font-bold mt-1 leading-relaxed">${kpi.desc}</p>
                                </div>
                                <div class="flex flex-col items-end gap-1.5 shrink-0">
                                    <span id="preview-badge-${kpi.key}" class="text-[9px] font-black px-2.5 py-0.5 rounded-full ${flag.badgeClass}">
                                        ${flag.label}
                                    </span>
                                    <span class="text-[8px] text-slate-400 font-bold">الحالي: ${actualVal}${kpi.unit}</span>
                                </div>
                            </div>

                            <div class="grid grid-cols-3 gap-2 my-4">
                                <div class="flex flex-col gap-1 text-start">
                                    <label class="text-[9px] text-slate-500 font-black">المستهدف (${kpi.unit}):</label>
                                    <input type="number" 
                                           id="input-target-${kpi.key}" 
                                           value="${config.target}" 
                                           step="${kpi.step}"
                                           oninput="updateKpiSetting('${kpi.key}', 'target', this.value)"
                                           class="bg-white border border-slate-200 text-center font-bold text-slate-800 text-xs p-2 rounded-xl focus:border-[#ca9b29] outline-hidden" />
                                </div>
                                
                                <div class="flex flex-col gap-1 text-start">
                                    <label class="text-[9px] text-emerald-600 font-black">${kpi.isInverse ? 'ممتاز (أقل من/يساوي):' : 'ممتاز (أكبر من/يساوي):'}</label>
                                    <input type="number" 
                                           id="input-excellent-${kpi.key}" 
                                           value="${excellentVal}" 
                                           step="${kpi.step}"
                                           oninput="updateKpiSetting('${kpi.key}', '${kpi.isInverse ? 'excellentMax' : 'excellentMin'}', this.value)"
                                           class="bg-white border border-emerald-200 text-center font-bold text-emerald-700 text-xs p-2 rounded-xl focus:border-emerald-500 outline-hidden" />
                                </div>

                                <div class="flex flex-col gap-1 text-start">
                                    <label class="text-[9px] text-amber-600 font-black">${kpi.isInverse ? 'جيد (أقل من/يساوي):' : 'جيد (أكبر من/يساوي):'}</label>
                                    <input type="number" 
                                           id="input-good-${kpi.key}" 
                                           value="${goodVal}" 
                                           step="${kpi.step}"
                                           oninput="updateKpiSetting('${kpi.key}', '${kpi.isInverse ? 'goodMax' : 'goodMin'}', this.value)"
                                           class="bg-white border border-amber-200 text-center font-bold text-amber-700 text-xs p-2 rounded-xl focus:border-amber-500 outline-hidden" />
                                </div>
                            </div>

                            <div class="text-[8px] font-black border rounded-lg p-2 text-center mt-2.5 text-rose-700 bg-rose-50 border-rose-200">
                                <span>ضعيف 🔴: يتم حسابه تلقائياً لأي قيمة ${kpi.isInverse ? 'أكبر من' : 'أقل من'} </span>
                                <span id="label-bad-${kpi.key}" class="font-bold font-mono text-sm mx-1">${goodVal}</span>
                                <span>${kpi.unit}</span>
                            </div>
                        </div>

                        <div class="flex justify-between items-center border-t border-slate-100 pt-3 text-[9px] font-bold text-slate-400 mt-3.5">
                            <span>كفاءة تصنيف النطاق: نشطة ومطابقة</span>
                            <div class="flex gap-2">
                                <button onclick="setPreset('${kpi.key}')" class="hover:text-[#ca9b29] transition-colors cursor-pointer"><i class="fa-solid fa-rotate-left me-1"></i>الافتراضي</button>
                            </div>
                        </div>
                    </div>
                `;
                container.innerHTML += kpiHtml;
            });
        }

        function updateKpiSetting(key, field, value) {
            const valNum = parseFloat(value);
            if (isNaN(valNum)) return;

            currentSettings[key][field] = valNum;

            if (field === 'goodMin' || field === 'goodMax') {
                const badLabel = document.getElementById(`label-bad-${key}`);
                if (badLabel) badLabel.innerText = valNum;
            }

            const actual = actualValues[key];
            let kpi = null;
            Object.keys(kpiDefinition).forEach(cat => {
                kpiDefinition[cat].kpis.forEach(item => {
                    if (item.key === key) kpi = item;
                });
            });

            if (kpi) {
                const flag = calculateFlag(key, actual, kpi.isInverse);
                const badge = document.getElementById(`preview-badge-${key}`);
                if (badge) {
                    badge.innerText = flag.label;
                    badge.className = `text-[9px] font-black px-2.5 py-0.5 rounded-full ${flag.badgeClass}`;
                }
            }
        }

        function setPreset(key) {
            currentSettings[key] = { ...defaultSettings[key] };
            
            const kpi = findKpiDef(key);
            const isInverse = kpi ? kpi.isInverse : false;
            
            const targetInput = document.getElementById(`input-target-${key}`);
            const excellentInput = document.getElementById(`input-excellent-${key}`);
            const goodInput = document.getElementById(`input-good-${key}`);
            
            if (targetInput) targetInput.value = currentSettings[key].target;
            if (excellentInput) excellentInput.value = isInverse ? currentSettings[key].excellentMax : currentSettings[key].excellentMin;
            if (goodInput) goodInput.value = isInverse ? currentSettings[key].goodMax : currentSettings[key].goodMin;

            const badLabel = document.getElementById(`label-bad-${key}`);
            if (badLabel) badLabel.innerText = isInverse ? currentSettings[key].goodMax : currentSettings[key].goodMin;

            const actual = actualValues[key];
            const flag = calculateFlag(key, actual, isInverse);
            const badge = document.getElementById(`preview-badge-${key}`);
            if (badge) {
                badge.innerText = flag.label;
                badge.className = `text-[9px] font-black px-2.5 py-0.5 rounded-full ${flag.badgeClass}`;
            }
        }

        function findKpiDef(key) {
            let found = null;
            Object.keys(kpiDefinition).forEach(cat => {
                kpiDefinition[cat].kpis.forEach(kpi => {
                    if (kpi.key === key) found = kpi;
                });
            });
            return found;
        }

        function saveTargets() {
            const compatTargets = {};
            Object.keys(currentSettings).forEach(key => {
                compatTargets[key] = currentSettings[key].target;
            });
            localStorage.setItem('kpi_targets', JSON.stringify(compatTargets));
            localStorage.setItem('kpi_settings', JSON.stringify(currentSettings));
            openSuccessModal();
        }

        function resetToDefaults() {
            currentSettings = JSON.parse(JSON.stringify(defaultSettings));
            renderKpis();
            
            const compatTargets = {};
            Object.keys(currentSettings).forEach(key => {
                compatTargets[key] = currentSettings[key].target;
            });
            localStorage.setItem('kpi_targets', JSON.stringify(compatTargets));
            localStorage.setItem('kpi_settings', JSON.stringify(currentSettings));
        }

        function openSuccessModal() {
            const modal = document.getElementById('successModal');
            const overlay = document.getElementById('successModalOverlay');
            const box = document.getElementById('successModalBox');
            
            if (modal && overlay && box) {
                modal.classList.remove('hidden');
                setTimeout(() => {
                    overlay.classList.remove('opacity-0');
                    box.classList.remove('scale-90', 'opacity-0');
                    box.classList.add('scale-100', 'opacity-100');
                }, 50);
            }
        }

        function closeSuccessModal() {
            const modal = document.getElementById('successModal');
            const overlay = document.getElementById('successModalOverlay');
            const box = document.getElementById('successModalBox');
            
            if (modal && overlay && box) {
                box.classList.remove('scale-100', 'opacity-100');
                box.classList.add('scale-90', 'opacity-0');
                overlay.classList.add('opacity-0');
                
                setTimeout(() => {
                    modal.classList.add('hidden');
                    window.location.href = '/Index';
                }, 300);
            }
        }

        function openProfileModal() {
            const modal = document.getElementById('profileModal');
            const overlay = document.getElementById('profileModalOverlay');
            const box = document.getElementById('profileModalBox');
            if (modal && overlay && box) {
                modal.classList.remove('hidden');
                setTimeout(() => {
                    overlay.classList.remove('opacity-0');
                    box.classList.remove('scale-90', 'opacity-0');
                    box.classList.add('scale-100', 'opacity-100');
                }, 50);
            }
        }

        function closeProfileModal() {
            const modal = document.getElementById('profileModal');
            const overlay = document.getElementById('profileModalOverlay');
            const box = document.getElementById('profileModalBox');
            if (modal && overlay && box) {
                box.classList.remove('scale-100', 'opacity-100');
                box.classList.add('scale-90', 'opacity-0');
                overlay.classList.add('opacity-0');
                setTimeout(() => { modal.classList.add('hidden'); }, 300);
            }
        }

        document.addEventListener("DOMContentLoaded", function() {
            initSettings();
            switchCategory('finance');
        });
    </script>
</body>
</html>
