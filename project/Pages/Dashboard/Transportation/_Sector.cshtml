@model project.Pages.IndexModel

<!-- ================= رواحل للنقل التخصصي (Specialized Transportation View) ================= -->
<div id="view-transportation-sector" class="view-container hidden">
    <section class="mb-6" data-aos="fade-up">
        <div class="bg-white rounded-3xl p-6 text-slate-800 border border-[#b0841a]/30 relative overflow-hidden">
            <div class="absolute -right-24 -top-24 w-64 h-64 bg-[#b0841a]/5 rounded-full blur-3xl"></div>
            <div class="flex flex-col sm:flex-row justify-between items-center gap-4 relative z-10 text-start">
                <div>
                    <span class="bg-[#b0841a]/10 text-[#b0841a] text-[10px] px-3.5 py-1.5 rounded-full font-bold border border-[#b0841a]/20">المنصة التنفيذية التشغيلية</span>
                    <h2 class="text-lg font-black mt-2 text-slate-800">إدارات وأقسام رواحل للنقل التخصصي</h2>
                    <p class="text-slate-500 text-xs leading-relaxed font-semibold mt-1">بوابة المراقبة والتحليل الموحد لهيكل إدارات إدارة النقل وأسطول الحافلات والحج والتشغيل.</p>
                </div>
                <button onclick="showView('overview')" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 border border-slate-200 text-xs font-black rounded-xl text-slate-800 flex items-center gap-1.5 transition">
                    <i class="fa-solid fa-arrow-right"></i>
                    <span>العودة للرئيسية</span>
                </button>
            </div>
        </div>
    </section>

    <!-- 4 Top Executive KPIs for Sector -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8 text-start" data-aos="fade-up">
        <div class="glass-card p-5 rounded-2xl border-l-4 border-[#b0841a] flex flex-col justify-between h-32">
            <span class="text-xs text-slate-500 font-bold flex items-center gap-1"><i class="fa-solid fa-coins text-[#b0841a]"></i> إجمالي الإيرادات</span>
            <span class="text-2xl font-black text-slate-900 mt-2">142.5 مليون ر.س</span>
            <span class="text-[9px] text-emerald-600 font-black">+8.2% نمو سنوي</span>
        </div>
        <div class="glass-card p-5 rounded-2xl border-l-4 border-[#b0841a] flex flex-col justify-between h-32">
            <span class="text-xs text-slate-500 font-bold flex items-center gap-1"><i class="fa-solid fa-chart-line text-[#b0841a]"></i> معدل النمو للإدارة</span>
            <span class="text-2xl font-black text-slate-900 mt-2">+8.2%</span>
            <span class="text-[9px] text-slate-400 font-bold">مستقر مقارنة بالمستهدف</span>
        </div>
        <div class="glass-card p-5 rounded-2xl border-l-4 border-[#b0841a] flex flex-col justify-between h-32">
            <span class="text-xs text-slate-500 font-bold flex items-center gap-1"><i class="fa-solid fa-bullseye text-[#b0841a]"></i> تحقيق المستهدفات</span>
            <span class="text-2xl font-black text-slate-900 mt-2">91%</span>
            <div class="w-full bg-slate-100 rounded-full h-1.5 mt-2">
                <div class="bg-gradient-to-r from-[#b0841a] to-[#8c6510] h-1.5 rounded-full" style="width: 91%"></div>
            </div>
        </div>
        <div class="glass-card p-5 rounded-2xl border-l-4 border-[#b0841a] flex flex-col justify-between h-32">
            <span class="text-xs text-slate-500 font-bold flex items-center gap-1"><i class="fa-solid fa-gears text-[#b0841a]"></i> إجمالي العمليات والرحلات</span>
            <span class="text-2xl font-black text-slate-900 mt-2">12,420 رحلة</span>
            <span class="text-[9px] text-slate-400 font-bold">مسجلة بالخطة التشغيلية</span>
        </div>
    </div>

    <!-- Streamlined 2-Card Portal Options -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8 text-start" data-aos="fade-up">
        <!-- Card 1: All Departments (كافة الإدارات) -->
        <div onclick="showView('transportation-departments')" class="glass-card p-10 rounded-3xl cursor-pointer flex flex-col justify-between min-h-[320px] group bg-white border-2 border-[#b0841a]/15 hover:border-[#b0841a] transition-all duration-350 shadow-md hover:shadow-xl">
            <div class="flex justify-between items-start gap-4">
                <div>
                    <span class="bg-[#b0841a]/10 text-[#b0841a] text-xs px-4 py-2 rounded-full font-bold border border-[#b0841a]/20" data-i18n="sect-trans-depts-title">كافة الإدارات</span>
                    <h3 class="text-2xl font-black text-slate-900 mt-5 flex items-center gap-3">
                        <i class="fa-solid fa-sitemap text-[#b0841a] text-3xl group-hover:scale-110 transition-transform duration-300"></i>
                        <span data-i18n="sect-trans-depts-title">كافة الإدارات</span>
                    </h3>
                    <p class="text-sm text-slate-500 font-semibold mt-4 leading-relaxed" data-i18n="sect-trans-depts-desc">استعراض كافة الإدارات والأقسام المساندة والتشغيلية الموحدة في قطاع النقل التخصصي.</p>
                </div>
                <span class="w-14 h-14 rounded-full bg-[#b0841a]/10 text-[#b0841a] flex items-center justify-center text-lg font-bold shrink-0 shadow-inner group-hover:bg-[#b0841a] group-hover:text-white transition-all duration-300"><i class="fa-solid fa-arrow-left ltr:rotate-180 text-xl"></i></span>
            </div>
            <div class="mt-6 flex justify-between items-end border-t border-slate-100 pt-5">
                <span class="text-xs text-[#b0841a] font-bold">10 إدارات مساندة وتوجيهية</span>
                <span class="text-xs bg-slate-100 text-slate-600 px-3 py-1.5 rounded-lg font-black border border-slate-200">DEPARTMENTS</span>
            </div>
        </div>

        <!-- Card 2: Services (الخدمات) -->
        <div onclick="showView('transportation-services')" class="glass-card p-10 rounded-3xl cursor-pointer flex flex-col justify-between min-h-[320px] group bg-white border-2 border-[#b0841a]/15 hover:border-[#b0841a] transition-all duration-350 shadow-md hover:shadow-xl">
            <div class="flex justify-between items-start gap-4">
                <div>
                    <span class="bg-[#b0841a]/10 text-[#b0841a] text-xs px-4 py-2 rounded-full font-bold border border-[#b0841a]/20" data-i18n="sect-trans-services-title">خدمات القطاع</span>
                    <h3 class="text-2xl font-black text-slate-900 mt-5 flex items-center gap-3">
                        <i class="fa-solid fa-bell-concierge text-[#b0841a] text-3xl group-hover:scale-110 transition-transform duration-300"></i>
                        <span data-i18n="sect-trans-services-title">خدمات القطاع</span>
                    </h3>
                    <p class="text-sm text-slate-500 font-semibold mt-4 leading-relaxed" data-i18n="sect-trans-services-desc">استعراض وتحليل الخدمات الأساسية للنقل التخصصي: العقود والاتفاقيات، الحج والعمرة، وخدمات الإيجار والتشغيل.</p>
                </div>
                <span class="w-14 h-14 rounded-full bg-[#b0841a]/10 text-[#b0841a] flex items-center justify-center text-lg font-bold shrink-0 shadow-inner group-hover:bg-[#b0841a] group-hover:text-white transition-all duration-300"><i class="fa-solid fa-arrow-left ltr:rotate-180 text-xl"></i></span>
            </div>
            <div class="mt-6 flex justify-between items-end border-t border-slate-100 pt-5">
                <span class="text-xs text-[#b0841a] font-bold">3 خدمات أساسية</span>
                <span class="text-xs bg-slate-100 text-slate-600 px-3 py-1.5 rounded-lg font-black border border-slate-200">SERVICES</span>
            </div>
        </div>
    </section>
</div>

<!-- ================= Specialized Transportation Services View ================= -->
