@model project.Pages.IndexModel

<!-- Hajj Transport Service KPI Cards -->
<!-- Fleet Readiness -->
<div id="card-fleet-ready" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-fleet-ready-title">نسبة جاهزية أسطول الحافلات</span>
        <span id="flag-fleet-ready" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-fleet-ready">@Model.FleetReady%</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-fleet-ready">--</span></span>
    </div>
</div>

<!-- Operations Plan Commitment -->
<div id="card-ops-plan" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-ops-plan-title">الالتزام بالخطة التشغيلية</span>
        <span id="flag-ops-plan" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-ops-plan">@Model.OpsPlan%</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-ops-plan">--</span></span>
    </div>
</div>

<!-- Customer Satisfaction NPS -->
<div id="card-nps" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-nps-title">صافي نقاط رضا العملاء NPS</span>
        <span id="flag-nps" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-nps">@Model.Nps</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-nps">--</span></span>
    </div>
</div>

<!-- Driver Route Schedule Adherence -->
<div id="card-hajj-driver-adherence" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-hajj-driver-adherence-title">التزام السائقين بالخطة</span>
        <span id="flag-hajj-driver-adherence" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-hajj-driver-adherence">--</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-hajj-driver-adherence">--</span></span>
    </div>
</div>

<!-- Fleet Fuel Consumption Efficiency -->
<div id="card-hajj-fuel-efficiency" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-hajj-fuel-efficiency-title">كفاءة استهلاك الوقود للأسطول</span>
        <span id="flag-hajj-fuel-efficiency" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-hajj-fuel-efficiency">--</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-hajj-fuel-efficiency">--</span></span>
    </div>
</div>

<!-- Drivers Safety Training Coverage -->
<div id="card-hajj-safety-training-rate" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-hajj-safety-training-rate-title">نسبة التدريب على السلامة</span>
        <span id="flag-hajj-safety-training-rate" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-hajj-safety-training-rate">--</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-hajj-safety-training-rate">--</span></span>
    </div>
</div>
