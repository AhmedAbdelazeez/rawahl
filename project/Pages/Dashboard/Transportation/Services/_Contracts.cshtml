@model project.Pages.IndexModel

<!-- Contracts & Agreements Service KPI Cards -->
<!-- New Contracts -->
<div id="card-new-contracts" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-new-contracts-title">عدد العقود الاستراتيجية الجديدة</span>
        <span id="flag-new-contracts" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-new-contracts">@Model.NewContracts</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-new-contracts">--</span></span>
    </div>
</div>

<!-- Customer Retention -->
<div id="card-cust-ret" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-cust-ret-title">نسبة الاحتفاظ بالعملاء</span>
        <span id="flag-cust-ret" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-cust-ret">@Model.CustRetention%</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-cust-ret">--</span></span>
    </div>
</div>

<!-- Audit Compliance -->
<div id="card-audit-comp" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="val-audit-comp-label">نسبة الامتثال للوائح والتراخيص</span>
        <span id="flag-audit-comp" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-audit-comp">@Model.AuditCompliance%</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-audit-comp">--</span></span>
    </div>
</div>

<!-- Contracts Renewal Rate -->
<div id="card-contracts-renewal-rate" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-contracts-renewal-rate-title">معدل تجديد العقود والاتفاقيات</span>
        <span id="flag-contracts-renewal-rate" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-contracts-renewal-rate">--</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-contracts-renewal-rate">--</span></span>
    </div>
</div>

<!-- Contracts Turnaround Time -->
<div id="card-contracts-turnaround-time" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-contracts-turnaround-time-title">متوسط زمن توقيع العقود</span>
        <span id="flag-contracts-turnaround-time" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-contracts-turnaround-time">--</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-contracts-turnaround-time">--</span></span>
    </div>
</div>

<!-- Contracts Legal Disputes -->
<div id="card-contracts-legal-disputes" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-contracts-legal-disputes-title">النزاعات القانونية النشطة</span>
        <span id="flag-contracts-legal-disputes" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-contracts-legal-disputes">--</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-contracts-legal-disputes">--</span></span>
    </div>
</div>
