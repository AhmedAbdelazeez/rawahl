@model project.Pages.IndexModel

<!-- Rental & Operations Service KPI Cards -->
<!-- Rental Fleet Utilization -->
<div id="card-rental-fleet-utilization" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-rental-fleet-utilization-title">معدل استغلال حافلات التأجير</span>
        <span id="flag-rental-fleet-utilization" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-rental-fleet-utilization">--</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-rental-fleet-utilization">--</span></span>
    </div>
</div>

<!-- Rental Revenue Per Bus -->
