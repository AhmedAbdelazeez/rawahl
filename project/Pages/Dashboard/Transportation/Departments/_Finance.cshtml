@model project.Pages.IndexModel

<!-- Financial Department KPI Cards -->
<!-- Revenue Growth -->
<div id="card-rev-growth" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-rev-growth-title">إجمالي الإيرادات ومعدل النمو</span>
        <span id="flag-rev-growth" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-rev-growth">@Model.TotalRevenue مليون ر.س</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-rev-growth">--</span></span>
    </div>
</div>

<!-- EBITDA -->
<div id="card-ebitda" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-ebitda-title">هامش EBITDA التشغيلي</span>
        <span id="flag-ebitda" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-ebitda">@Model.Ebitda%</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-ebitda">--</span></span>
    </div>
</div>

<!-- Cash Flow -->
<div id="card-cashflow" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-cashflow-title">التدفق النقدي التشغيلي</span>
        <span id="flag-cashflow" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-cashflow">@Model.CashFlow مليون ر.س</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-cashflow">--</span></span>
    </div>
</div>

<!-- ROA -->
<div id="card-roa" class="glass-card p-5 rounded-2xl flex flex-col justify-between h-40">
    <div class="flex justify-between items-start mb-2">
        <span class="text-[11px] font-black text-slate-800" data-i18n="card-roa-title">العائد على الأصول ROA</span>
        <span id="flag-roa" class="text-[9px] font-bold px-2 py-0.5 rounded-full">--</span>
    </div>
    <div class="my-2 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-slate-900" id="val-roa">@Model.Roa%</span>
        <span class="text-[10px] text-slate-500 font-bold mt-1.5">المستهدف: <span id="target-val-roa">--</span></span>
    </div>
</div>
