@page
@model project.Pages.Users.IndexModel
@{
    Layout = null;
    ViewData["Title"] = "إدارة المستخدمين - شركة رواحل المشاعر";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <!-- Tailwind CSS v4 -->
    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@4"></script>
    <!-- Google Fonts - Tajawal -->
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;850;900&display=swap" rel="stylesheet">
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            font-family: 'Tajawal', sans-serif;
            background-image: linear-gradient(rgba(250, 249, 246, 0.96), rgba(250, 249, 246, 0.96)), url('https://www.rawahel.com.sa/wp-content/themes/tl4s-raoaa_rawahel/images/slider10.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
            color: #1e293b;
        }
    </style>
</head>
<body class="min-h-screen py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto space-y-6">
        <!-- Header area -->
        <div class="flex flex-col md:flex-row md:items-center md:justify-between bg-white rounded-2xl p-6 shadow-sm border border-slate-100 gap-4">
            <div class="flex items-center gap-4">
                <div class="p-3 bg-[#b0841a]/10 text-[#b0841a] rounded-xl">
                    <i class="fas fa-users-cog text-3xl"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-slate-800">إدارة المستخدمين والصلاحيات</h1>
                    <p class="text-sm text-slate-500 mt-1">تحديد الأدوار، وتوزيع الصلاحيات على القطاعات والأقسام المختلفة</p>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <a href="/" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold rounded-xl text-sm transition duration-150">
                    <i class="fas fa-arrow-right ml-1"></i> لوحة المؤشرات
                </a>
                <a href="/Users/Create" class="px-4 py-2 bg-gradient-to-l from-[#b0841a] to-[#8c6510] text-white font-bold rounded-xl text-sm shadow-md hover:shadow-lg transition duration-150">
                    <i class="fas fa-user-plus ml-1"></i> إضافة مستخدم جديد
                </a>
            </div>
        </div>

        @if (!ModelState.IsValid)
        {
            <div class="p-4 bg-red-50 border-r-4 border-red-500 rounded-xl text-red-700 text-sm">
                <div asp-validation-summary="All" class="list-none"></div>
            </div>
        }

        <!-- Filter bar -->
        <div class="bg-white rounded-2xl p-4 shadow-sm border border-slate-100 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <form method="get" class="w-full md:max-w-md relative">
                <input type="text" name="SearchTerm" value="@Model.SearchTerm" placeholder="بحث باسم المستخدم، البريد الإلكتروني، أو الدور..." 
                       class="w-full pr-10 pl-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-[#b0841a] focus:ring-1 focus:ring-[#b0841a] transition" />
                <button type="submit" class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-[#b0841a]">
                    <i class="fas fa-search"></i>
                </button>
            </form>
            <div class="text-xs text-slate-400">
                إجمالي المستخدمين: <span class="font-bold text-slate-700">@Model.UsersList.Count</span>
            </div>
        </div>

        <!-- Users Table -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-right border-collapse">
                    <thead>
                        <tr class="bg-slate-50 border-b border-slate-100 text-slate-500 text-xs font-semibold uppercase">
                            <th class="p-4">المستخدم</th>
                            <th class="p-4">البريد الإلكتروني</th>
                            <th class="p-4">الدور</th>
                            <th class="p-4">القطاعات المصرح بها</th>
                            <th class="p-4 text-center">الحالة</th>
                            <th class="p-4">آخر دخول</th>
                            <th class="p-4 text-center">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 text-sm">
                        @if (Model.UsersList.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="p-8 text-center text-slate-400">
                                    <i class="fas fa-user-slash text-4xl mb-2 block"></i>
                                    لا يوجد مستخدمين مطابقين للبحث.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var user in Model.UsersList)
                            {
                                <tr class="hover:bg-slate-50/50 transition">
                                    <td class="p-4">
                                        <div class="flex items-center gap-3">
                                            <div class="h-10 w-10 rounded-full bg-gradient-to-br from-[#b0841a]/20 to-[#8c6510]/10 text-[#b0841a] flex items-center justify-center font-bold text-base">
                                                @(string.IsNullOrEmpty(user.ArabicDisplayName) ? "?" : user.ArabicDisplayName[0].ToString())
                                            </div>
                                            <div>
                                                <div class="font-bold text-slate-800">@user.ArabicDisplayName</div>
                                                <div class="text-xs text-slate-400">@user.FullName</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="p-4 text-slate-600 font-mono text-xs">@user.Email</td>
                                    <td class="p-4">
                                        @if (user.Role == "SuperAdmin")
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 border border-amber-200">
                                                <i class="fas fa-crown ml-1 text-2xs"></i> مدير عام
                                            </span>
                                        }
                                        else if (user.Role == "Admin")
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 border border-blue-200">
                                                <i class="fas fa-user-shield ml-1 text-2xs"></i> مسؤول نظام
                                            </span>
                                        }
                                        else if (user.Role == "Manager")
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800 border border-purple-200">
                                                <i class="fas fa-user-tie ml-1 text-2xs"></i> مدير قطاع
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-800 border border-slate-200">
                                                <i class="fas fa-user ml-1 text-2xs"></i> مستخدم قطاع
                                            </span>
                                        }
                                    </td>
                                    <td class="p-4">
                                        @if (user.Role == "SuperAdmin" || user.Role == "Admin")
                                        {
                                            <span class="text-xs text-slate-400 italic">وصول كامل لكافة القطاعات</span>
                                        }
                                        else if (user.Departments.Count == 0)
                                        {
                                            <span class="text-xs text-red-400 italic">لم يتم تعيين قطاعات</span>
                                        }
                                        else
                                        {
                                            <div class="flex flex-wrap gap-1 max-w-xs">
                                                @foreach (var dept in user.Departments)
                                                {
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-lg text-2xs font-semibold bg-slate-100 text-slate-600 border border-slate-200">
                                                        @dept
                                                    </span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td class="p-4 text-center">
                                        @if (user.IsActive)
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800">
                                                نشط
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-rose-100 text-rose-800">
                                                معطل
                                            </span>
                                        }
                                    </td>
                                    <td class="p-4 text-xs text-slate-500 font-mono">
                                        @(user.LastLoginAt?.AddHours(3).ToString("yyyy-MM-dd HH:mm") ?? "لم يدخل بعد")
                                    </td>
                                    <td class="p-4 text-center">
                                        <div class="flex items-center justify-center gap-2">
                                            <a href="/Users/Edit?id=@user.Id" class="p-1.5 text-slate-400 hover:text-[#b0841a] transition" title="تعديل">
                                                <i class="fas fa-edit text-base"></i>
                                            </a>
                                            
                                            @if (user.Email != "ceo@rawahil.local" && user.Email != User.Identity?.Name)
                                            {
                                                <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id" onsubmit="return confirm('هل أنت متأكد من حذف هذا المستخدم؟');" class="inline">
                                                    <button type="submit" class="p-1.5 text-slate-400 hover:text-red-500 transition cursor-pointer">
                                                        <i class="fas fa-trash-alt text-base"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <button disabled class="p-1.5 text-slate-200 cursor-not-allowed">
                                                    <i class="fas fa-trash-alt text-base"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
