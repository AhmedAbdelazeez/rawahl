@page
@model IndexModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title data-i18n="company-name-main">شركة رواحل المشاعر - لوحة قياس الأداء</title>

    <!-- Tailwind CSS (Tailwind CSS v3 CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        gold: {
                            brand: '#b0841a',
                            light: '#faf6ec',
                            hover: '#ca9b29'
                        }
                    },
                    backdropBlur: {
                        xs: '2px',
                    },
                    boxShadow: {
                        '3xs': '0 1px 2px rgba(176, 132, 26, 0.05)',
                    }
                }
            }
        }
    </script>
    
    <!-- FontAwesome 6 icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- Google Fonts: Tajawal (Arabic) and Outfit (English) -->
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&family=Outfit:wght@400;500;700;900&display=swap" rel="stylesheet">
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- AOS Library for animations -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <!-- Modular Stylesheets -->
    <link rel="stylesheet" href="~/css/dashboard/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard/transportation.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard/tourism.css" asp-append-version="true" />
</head>
<body class="antialiased selection:bg-[#b0841a] selection:text-white">

    <!-- Ticker News Bar (إخباري سفلي لانهائي) -->
    <partial name="Dashboard/Shared/_Ticker" />

    <!-- Main Container -->
    <div class="flex min-h-screen relative">
        
        <!-- Left Sidebar Navigation Panel -->
        <partial name="Dashboard/Shared/_Sidebar" />

        <!-- Main Content Area -->
        <main class="flex-1 min-h-screen flex flex-col p-4 sm:p-6 lg:p-8 overflow-x-hidden pt-20 text-slate-800">
            
            <!-- Top Header Navbar Panel -->
            <partial name="Dashboard/Shared/_Header" />

            <!-- I. Overview & Unified Performance Analysis (الرئيسية والتحليل الموحد) -->
            <partial name="Dashboard/Shared/_Overview" />

            <!-- II. Sectors selection grid view (قطاعات الشركة) -->
            <partial name="Dashboard/Shared/_SectorsGrid" />

            <!-- III. Specialized Transportation Portal Views (بوابة النقل التخصصي) -->
            <partial name="Dashboard/Transportation/_Sector" />

            <!-- IV. Specialized Transportation Departments views (إدارة الامتثال والمشاريع) -->
            <partial name="Dashboard/Transportation/Departments/_Compliance" />
            <partial name="Dashboard/Transportation/Departments/_Projects" />
            <partial name="Dashboard/Transportation/Departments/_ProjectShuttle" />
            <partial name="Dashboard/Transportation/Departments/_ProjectMakkahTour" />

            <!-- V. Tourism & Pilgrim Services Portal Views (بوابة خدمات العمرة والسياحة) -->
            <partial name="Dashboard/Tourism/_Sector" />

            <!-- VI. Common Company Departments List Grid (كافة إدارات الشركة) -->
            <partial name="Dashboard/Shared/_DepartmentsGrid" />

            <!-- VII. KPI Dashboard Container for Dynamic cards (لوحة تفاصيل الإدارات والخدمات) -->
            <partial name="Dashboard/Shared/_KpiDashboard" />

        </main>
    </div>

    <!-- Drilldown & Profile Modals -->
    <partial name="Dashboard/Shared/_Modals" />

    <!-- Razor Bindings to window.RAWAHEL_DATA Bridge object for cached scripts -->
    <script>
        window.RAWAHEL_DATA = {
            allowedDepts: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AllowedDepartmentCodes)),
            isTransportationManager: @Model.IsTransportationManager.ToString().ToLower(),
            isPilgrimServicesManager: @Model.IsPilgrimServicesManager.ToString().ToLower(),
            revenueGrowth: @(Model.TotalRevenue / 118.75 * 100 - 100),
            ebitda: @Model.Ebitda,
            cashFlow: @Model.CashFlow,
            roa: @Model.Roa,
            custRetention: @Model.CustRetention,
            nps: @Model.Nps,
            newContracts: @Model.NewContracts,
            opsPlan: @Model.OpsPlan,
            fleetReady: @Model.FleetReady,
            fleetUtil: @Model.FleetUtil,
            hrRetention: @Model.HrRetention,
            itAutomation: @Model.ItAutomation,
            criticalSuccession: @Model.CriticalSuccession,
            saudization: @Model.Saudization,
            ltifr: @Model.Ltifr,
            accidents: @Model.Accidents,
            auditCompliance: @Model.AuditCompliance,
            strategicGoals: @Model.StrategicGoals,
            strategicInitiatives: @Model.StrategicInitiatives,
            riskHandling: @Model.RiskHandling,
            govMaturity: @Model.GovMaturity,
            stratGoalsAchieve: @Model.StratGoalsAchieve,
            visaIntegrationUptime: @Model.VisaIntegrationUptime,
            visaDataErrorRate: @Model.VisaDataErrorRate,
            visaComplaintsRate: @Model.VisaComplaintsRate,
            hotelAverageRoomRate: @Model.HotelAverageRoomRate,
            hotelOverbookingIncidents: @Model.HotelOverbookingIncidents,
            hotelContractCompliance: @Model.HotelContractCompliance,
            pilgrimBusMaintenanceAdherence: @Model.PilgrimBusMaintenanceAdherence,
            pilgrimTripDuration: @Model.PilgrimTripDuration,
            pilgrimSatisfaction: @Model.PilgrimSatisfaction,
            mealWastePercentage: @Model.MealWastePercentage,
            hospitalityStaffCompliance: @Model.HospitalityStaffCompliance,
            hospitalityComplaints: @Model.HospitalityComplaints,
            contractsRenewalRate: @Model.ContractsRenewalRate,
            contractsTurnaroundTime: @Model.ContractsTurnaroundTime,
            contractsLegalDisputes: @Model.ContractsLegalDisputes,
            hajjDriverAdherence: @Model.HajjDriverAdherence,
            hajjFuelEfficiency: @Model.HajjFuelEfficiency,
            hajjSafetyTrainingRate: @Model.HajjSafetyTrainingRate,
            rentalFleetUtilization: @Model.RentalFleetUtilization,
            rentalRevenuePerBus: @Model.RentalRevenuePerBus,
            rentalContractSatisfaction: @Model.RentalContractSatisfaction,
            rentalMaintenanceAdherence: @Model.RentalMaintenanceAdherence,
            rentalSafetyCompliance: @Model.RentalSafetyCompliance,
            rentalActiveContracts: @Model.RentalActiveContracts,
            opsD15: @Model.OpsD15,
            opsD16: @Model.OpsD16,
            opsD17: @Model.OpsD17,
            opsD18: @Model.OpsD18,
            opsD19: @Model.OpsD19,
            opsD20: @Model.OpsD20,
            opsD21: @Model.OpsD21,
            opsD22: @Model.OpsD22,
            opsD23: @Model.OpsD23,
            opsD24: @Model.OpsD24,
            opsD25: @Model.OpsD25,
            opsD26: @Model.OpsD26,
            opsD27: @Model.OpsD27,
            opsD28: @Model.OpsD28,
            opsD29: @Model.OpsD29,
            opsD30: @Model.OpsD30,
            opsD31: @Model.OpsD31,
            opsD32: @Model.OpsD32,
            comD10: @Model.ComD10,
            hseD15: @Model.HseD15
        };
    </script>

    <!-- AOS animation library script -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

    <!-- Modular Script loaders -->
    <script src="~/js/dashboard/common.js" asp-append-version="true"></script>
    <script src="~/js/dashboard/transportation.js" asp-append-version="true"></script>
    <script src="~/js/dashboard/tourism.js" asp-append-version="true"></script>
    <script src="~/js/dashboard/app.js" asp-append-version="true"></script>
</body>
</html>
