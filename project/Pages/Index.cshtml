                chartLabels: ['الأسبوع 1', 'الأسبوع 2', 'الأسبوع 3', 'الأسبوع 4'],
                chartData: (val) => [Math.round(val * 0.2), Math.round(val * 0.5), Math.round(val * 0.8), val]
            },
            'roa': {
                title: 'العائد على الأصول ROA',
                subtitle: 'ربحية تشغيل أسطول المركبات والحافلات',
                notes: 'الاستغلال الأمثل للحافلات الاحتياطية وإدخالها في رحلات السياحة القصيرة يرفع عائد تشغيل أصول الأسطول بشكل فوري.',
                chartType: 'polarArea',
                subKpis: (val) => [
                    { name: 'عائد أسطول الحافلات السياحية', value: Math.round(val * 1.2) + '%', target: '15%', flag: 'excellent' },
                    { name: 'عائد حافلات النقل التجاري والمدرسي', value: Math.round(val * 0.8) + '%', target: '10%', flag: 'good' }
