    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        // تشغيل أنيميشن التمرير مع حماية الأخطاء
        try {
            AOS.init({ duration: 800, once: true });
        } catch (e) {
            console.warn("AOS animation library could not be loaded:", e);
        }

        // الأهداف والمستهدفات الافتراضية للنظام
        const defaultTargets = {
            'rev-growth': 150,
            'ebitda': 35,
            'cashflow': 50,
            'roa': 12,
            'cust-ret': 85,
            'nps': 70,
            'ops-plan': 90,
            'fleet-ready': 95,
            'fleet-util': 85,
            'hr-ret': 90,
            'it-autom': 80,
            'hse-ltifr': 1.5,
            'hse-accidents': 0,
            'audit-comp': 95,
            'strat-goals': 85,
            'strat-init': 90
        };

        // تحميل الأهداف من localStorage أو استخدام الافتراضية
        const kpiTargets = { ...defaultTargets };
        function loadTargets() {
            const saved = localStorage.getItem('kpi_targets');
            if (saved) {
                try {
                    const parsed = JSON.parse(saved);
                    Object.assign(kpiTargets, parsed);
                } catch (e) {
                    console.error("Error loading targets from localStorage:", e);
                }
            }
        }
        loadTargets();

        // هيكلية البيانات للمؤشرات الفرعية والمسارات التابعة (Drill Down Engine)
        const kpiSubKpis = {
            'rev-growth': {
                title: 'إجمالي الإيرادات وتحليل مسارات النقل الأكثر ربحية',
                subtitle: 'التحليل المالي - تفصيل المسارات والرحلات الأكثر جذباً للأموال',
                notes: 'مسار مكة-المدينة VIP ومسار قطار الحرمين هما الأكثر دراً للأموال بالشركة. نوصي بتكثيف الرحلات الإضافية وتوجيه الحافلات الفاخرة لهما لرفع المداخيل.',
                chartType: 'bar',
                subKpis: (val) => [
                    { name: 'مسار مكة - المدينة (VIP)', value: (val * 0.456).toFixed(1) + 'M ر.س', target: '60M ر.س', flag: (val * 0.456) >= 60 ? 'excellent' : 'good' },
                    { name: 'مسار قطار الحرمين - المشاعر المقدسة', value: (val * 0.267).toFixed(1) + 'M ر.س', target: '35M ر.س', flag: (val * 0.267) >= 35 ? 'excellent' : 'good' },
                    { name: 'مسار مطار جدة - مكة كلاسيك', value: (val * 0.172).toFixed(1) + 'M ر.س', target: '30M ر.س', flag: (val * 0.172) >= 30 ? 'excellent' : 'bad' },
                    { name: 'مسار النقل السياحي الموحد', value: (val * 0.105).toFixed(1) + 'M ر.س', target: '17M ر.س', flag: (val * 0.105) >= 17 ? 'good' : 'bad' }
                ],
                chartLabels: ['مكة-المدينة VIP', 'قطار الحرمين-المشاعر', 'مطار جدة-مكة', 'النقل السياحي الموحد'],
                chartData: (val) => [
                    parseFloat((val * 0.456).toFixed(1)),
                    parseFloat((val * 0.267).toFixed(1)),
                    parseFloat((val * 0.172).toFixed(1)),
                    parseFloat((val * 0.105).toFixed(1))
                ]
            },
            'ebitda': {
                title: 'هامش EBITDA',
                subtitle: 'الكفاءة التشغيلية والربحية قبل الضرائب والهلاك',
                notes: 'التحكم في التكاليف التشغيلية المباشرة وحساب مصروف المحروقات للرحلات بشكل مؤتمت يساهم مباشرة في الحفاظ على استقرار هامش EBITDA.',
                chartType: 'doughnut',
                subKpis: (val) => [
                    { name: 'كفاءة تشغيل الرحلات الدائرية', value: '94%', target: '95%', flag: 'good' },
                    { name: 'ترشيد كلفة وقود أسطول النقل', value: Math.round(val * 2.6) + '%', target: '95%', flag: 'excellent' },
                    { name: 'تكاليف الصيانة الدورية المخططة', value: '4.8M ر.س', target: '5.0M ر.س', flag: 'excellent' }
