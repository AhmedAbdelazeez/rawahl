                    { name: 'مبادرة صديقة البيئة للحافلات الخضراء', value: Math.round(val * 0.8) + '%', target: '90%', flag: 'good' }
                ],
                chartLabels: ['يناير', 'فبراير', 'مارس', 'أبريل', 'مايو'],
                chartData: (val) => [val - 20, val - 12, val - 5, val - 2, val]
