                chartLabels: ['توسيع الحصة السوقية', 'التحول الرقمي للورش', 'توطين السائقين', 'كفاءة الاستهلاك'],
                chartData: (val) => [Math.round(val * 0.9), Math.round(val * 1.03), Math.round(val * 0.82), Math.round(val * 1.05)]
