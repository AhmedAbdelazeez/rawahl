            'ops-plan': {
                title: 'نسبة الالتزام بالخطة التشغيلية',
                subtitle: 'مطابقة جدولة الرحلات الفعلية بالخطط الأساسية',
                notes: 'الأداء التشغيلي منضبط ويسجل نسب ممتازة. نقوم بتحديث نظام الجدولة الذكي لتلافي الازدحامات المرورية حول المشاعر المقدسة.',
                chartType: 'line',
                subKpis: (val) => [
                    { name: 'نسبة مطابقة مسارات الرحلات للحافلات', value: Math.round(val * 1.01) + '%', target: '95%', flag: 'excellent' },
                    { name: 'انضباط جدول ورديات حركة السائقين', value: Math.round(val * 0.99) + '%', target: '90%', flag: 'excellent' }
                ],
                chartLabels: ['الأسبوع 1', 'الأسبوع 2', 'الأسبوع 3', 'الأسبوع 4'],
                chartData: (val) => [val - 5, val - 2, val + 1, val]
            },
            'fleet-ready': {
                title: 'نسبة جاهزية الأسطول',
                subtitle: 'الصيانة الوقائية والأعطال وحالة الحافلات',
                notes: 'متابعة حية لصيانة 1,240 حافلة بورشة رواحل الرئيسية بمكة المكرمة للتأكد من الجاهزية الكاملة لمواسم الحج.',
                chartType: 'doughnut',
                subKpis: (val) => [
                    { name: 'حافلات جاهزة للعمل الفوري', value: Math.round(1240 * (val/100)) + ' حافلة', target: '1178 حافلة', flag: 'excellent' },
                    { name: 'حافلات في الصيانة الدورية الدائرية', value: Math.round(1240 * (1 - val/100) * 0.6) + ' حافلة', target: 'أقل من 30', flag: 'good' },
                    { name: 'حافلات في صيانة الأعطال الطارئة', value: Math.round(1240 * (1 - val/100) * 0.4) + ' حافلة', target: 'أقل من 20', flag: 'excellent' }
                ],
                chartLabels: ['جاهزية تامة للتشغيل', 'صيانة وقائية دورية', 'صيانة أعطال طارئة'],
                chartData: (val) => [val, Math.round((100-val)*0.6), Math.round((100-val)*0.4)]
            },
            'fleet-util': {
                title: 'نسبة استغلال الأسطول',
                subtitle: 'معدلات ساعات تشغيل الحافلة في اليوم',
                notes: 'معدل الاستغلال ممتاز ويصل لذروته بموسمي رمضان وموسم الحج. نقوم بتوزيع الحافلات السياحية لخدمة المطارات لتوازن الكثافة.',
                chartType: 'bar',
                subKpis: (val) => [
