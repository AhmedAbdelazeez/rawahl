                chartType: 'radar',
                subKpis: (val) => [
                    { name: 'نسبه خدمه العملاء الفورية', value: '@Model.NpsCustomerService' + '%', target: '50%', flag: 'bad' }, 
                    { name: 'نسبة تأخر الأسطول / الرحلات اليومية', value: '@Model.NpsFleetDelay' + '%', target: '5%', flag: 'bad' }, 
                    { name: 'معدل تقييم نظافة الحافلة', value: '@Model.NpsCleanliness' + '%', target: '95%', flag: 'good' },
                    { name: 'سرعة الاستجابة لشكاوى الركاب', value: '@Model.NpsComplaints' + '%', target: '80%', flag: 'bad' }
                ],
                chartLabels: ['خدمة العملاء (@Model.NpsCustomerService%)', 'تأخير الرحلات (@Model.NpsFleetDelay%)', 'نظافة الحافلات (@Model.NpsCleanliness%)', 'سرعة حل الشكاوى (@Model.NpsComplaints%)', 'راحة المقاعد'],
                chartData: (val) => [@Model.NpsCustomerService, @Model.NpsFleetDelay, @Model.NpsCleanliness, @Model.NpsComplaints, 70]
