                chartLabels: ['لوائح الحج والعمرة', 'معايير المرور والصلاحية', 'التراخيص البلدية', 'متمتلكات السلامة'],
                chartData: (val) => [val, val - 2, Math.min(val + 3, 100), val - 4]
