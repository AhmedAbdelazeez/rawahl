@page
@model IndexModel
@{
    Layout = null;
    ViewData["Title"] = "لوحة المؤشرات الذكية - شركة رواحل المشاعر";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <!-- Tailwind CSS للتنسيق العصري والمودرن -->
    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@4"></script>
    <!-- Google Fonts - IBM Plex Sans Arabic, Tajawal & Cairo الخط العربي المعتمد احترافياً و Outfit للإنجليزية -->
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;650;700&family=Tajawal:wght@300;400;500;700;850;900&family=Cairo:wght@300;400;600;700;900&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <!-- FontAwesome للأيقونات -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Chart.js للرسوم البيانية المتقدمة -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- AOS Library للأنيميشن الاحترافي -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <style>
        /* Load Tajawal as primary Arabic font */
        body, button, input, select, textarea, span, h1, h2, h3, h4, h5, h6, p, div, a {
            font-family: 'Tajawal', sans-serif;
        }

        html[dir="ltr"] body, html[dir="ltr"] button, html[dir="ltr"] input, html[dir="ltr"] select, html[dir="ltr"] textarea, html[dir="ltr"] span, html[dir="ltr"] h1, html[dir="ltr"] h2, html[dir="ltr"] h3, html[dir="ltr"] h4, html[dir="ltr"] h5, html[dir="ltr"] h6, html[dir="ltr"] p, html[dir="ltr"] div, html[dir="ltr"] a {
            font-family: 'Outfit', sans-serif;
        }

        body {
            background-image: linear-gradient(rgba(250, 249, 246, 0.98), rgba(250, 249, 246, 0.98)), url('https://www.rawahel.com.sa/wp-content/themes/tl4s-raoaa_rawahel/images/slider10.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
            color: #0f172a;
        }

        .bg-sidebar { background-color: #ffffff; }
        .bg-sidebar-active { 
            background: linear-gradient(135deg, #b0841a 0%, #8c6510 100%); 
            color: #ffffff !important; 
            box-shadow: 0 4px 15px rgba(176, 132, 26, 0.3); 
        }
        
        .text-gold-brand { color: #b0841a; }
        .bg-gold-brand { background-color: #b0841a; }

        /* glassmorphism components with glowing effects */
        .glass-card {
            background-color: #ffffff;
            border: 1px solid rgba(176, 132, 26, 0.35);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease-in-out;
            color: #0f172a;
        }
        .glass-card:hover {
            transform: translateY(-3px);
            border-color: rgba(176, 132, 26, 0.6);
            box-shadow: 0 10px 30px rgba(176, 132, 26, 0.15);
        }

        /* Core Sectors (Grid of 3) */
        #sectors-grid .glass-card {
            min-height: 16.5rem !important;
            height: auto !important;
            padding: 2rem !important;
            border-radius: 1.5rem !important;
            background: linear-gradient(135deg, #ffffff 0%, #faf6ec 100%) !important;
            border: 1.5px solid rgba(176, 132, 26, 0.5) !important;
            position: relative;
            overflow: hidden;
            box-shadow: 0 6px 20px rgba(176, 132, 26, 0.08) !important;
        }
        #sectors-grid .glass-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 5px;
            background: linear-gradient(90deg, #b0841a, #e2b34a, #8c6510);
        }
        #sectors-grid .glass-card h3 {
            font-size: 1.25rem !important;
            font-weight: 900 !important;
            color: #0f172a !important;
        }
        #sectors-grid .glass-card p {
            font-size: 0.95rem !important;
            line-height: 1.625 !important;
            font-weight: 500 !important;
            color: #475569 !important;
            margin-top: 0.75rem !important;
        }
        #sectors-grid .glass-card span[id^="sector-perf-"] {
            font-size: 2.75rem !important;
            font-weight: 900 !important;
        }
        #sectors-grid .glass-card span.w-10.h-10 {
            width: 3rem !important;
            height: 3rem !important;
            font-size: 1.125rem !important;
        }
        #sectors-grid .glass-card:hover {
            transform: translateY(-5px) !important;
            border-color: rgba(176, 132, 26, 0.8) !important;
            box-shadow: 0 15px 35px rgba(176, 132, 26, 0.22) !important;
        }

        /* Summary KPI Cards (Grid of 6) */
        #summary-cards-grid .glass-card {
            min-height: 11rem !important;
            height: auto !important;
            padding: 1.5rem !important;
            border-radius: 1.25rem !important;
        }
        #summary-cards-grid .glass-card span[data-i18n] {
            font-size: 0.95rem !important;
            font-weight: 850 !important;
            color: #0f172a !important;
            line-height: 1.4 !important;
        }
        #summary-cards-grid .glass-card span[id^="val-"] {
            font-size: 2.25rem !important;
            font-weight: 900 !important;
        }
        #summary-cards-grid .glass-card span[id^="target-val-"] {
            font-size: 0.85rem !important;
            font-weight: 700 !important;
        }

        /* Departments List Grid */
        #departments-grid .glass-card {
            min-height: 15rem !important;
            height: auto !important;
            padding: 2rem !important;
            border-radius: 1.5rem !important;
        }
        #departments-grid .glass-card h3 {
            font-size: 1.125rem !important;
            font-weight: 900 !important;
            color: #0f172a !important;
        }
        #departments-grid .glass-card p {
            font-size: 0.875rem !important;
            font-weight: 500 !important;
            color: #475569 !important;
            margin-top: 0.75rem !important;
            line-height: 1.6 !important;
        }
        #departments-grid .glass-card span.w-8.h-8 {
            width: 2.5rem !important;
            height: 2.5rem !important;
            font-size: 1rem !important;
        }
        #departments-grid .glass-card .mt-4 {
            margin-top: 1.5rem !important;
        }
        #departments-grid .glass-card .text-\[9px\] {
            font-size: 0.75rem !important;
            font-weight: 800 !important;
        }

        /* Detailed KPI Cards (Grid of 22 in sectors/depts) */
        #kpis-container .glass-card {
            min-height: 12rem !important;
            height: auto !important;
            padding: 1.5rem !important;
            border-radius: 1.5rem !important;
        }
        #kpis-container .glass-card span[data-i18n] {
            font-size: 0.875rem !important;
            font-weight: 850 !important;
            color: #0f172a !important;
        }
        #kpis-container .glass-card span[id^="val-"] {
            font-size: 2.25rem !important;
            font-weight: 900 !important;
            margin-top: 0.5rem !important;
            margin-bottom: 0.5rem !important;
        }
        #kpis-container .glass-card span[id^="target-val-"],
        #kpis-container .glass-card .text-slate-500 {
            font-size: 0.75rem !important;
            font-weight: 700 !important;
        }
        #kpis-container .glass-card .text-\[9px\] {
            font-size: 0.75rem !important;
            font-weight: 800 !important;
        }
        
        /* Sidebar Text Scaling */
        aside nav a {
            font-size: 0.875rem !important; /* text-sm */
            padding-top: 0.75rem !important;
            padding-bottom: 0.75rem !important;
        }
        aside nav .pt-3 {
            font-size: 0.75rem !important; /* text-xs */
        }
        aside .text-\[9px\] {
            font-size: 0.75rem !important;
        }
        
        .bg-amber-light-card { 
            background-color: #ffffff; 
            border: 1px solid rgba(176, 132, 26, 0.4); 
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            color: #0f172a;
        }

        /* ticker animations */
        /* ticker animations */
        .ticker-wrap {
            width: 100%;
            overflow: hidden;
            background: linear-gradient(90deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
            border-bottom: 3px solid #b0841a;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
            direction: ltr !important; 
            color: #f8fafc;
        }
        .ticker-wrap .text-[#b0841a] {
            color: #fbbf24 !important; /* glowing amber/gold */
            text-shadow: 0 0 8px rgba(251, 191, 36, 0.4);
        }
        .ticker-wrap .text-emerald-700 {
            color: #34d399 !important; /* light emerald/green */
            text-shadow: 0 0 8px rgba(52, 211, 153, 0.4);
        }
        .ticker-wrap .text-gold-brand {
            color: #f59e0b !important;
            text-shadow: 0 0 8px rgba(245, 158, 11, 0.4);
        }
        .ticker__item {
            font-size: 0.95rem !important; /* text-sm/base */
            padding: 0 4rem !important; /* wider spacing */
            height: 100%;
            display: inline-flex;
            align-items: center;
        }
        .ticker-container {
            display: flex;
            width: max-content;
            animation: ticker-loop 35s linear infinite;
        }
        .ticker {
            display: flex;
            white-space: nowrap;
        }
        html[dir="rtl"] .ticker { direction: rtl !important; }
        html[dir="ltr"] .ticker { direction: ltr !important; }
        @@keyframes ticker-loop {
            0% { transform: translate3d(0, 0, 0); }
            100% { transform: translate3d(-50%, 0, 0); }
        }
        .ticker-wrap:hover .ticker-container {
            animation-play-state: paused;
        }

        /* custom scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(240, 240, 240, 0.8);
        }
        ::-webkit-scrollbar-thumb {
            background: #b0841a;
            border-radius: 3px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #ca9b29;
        }

        @@keyframes spin-slow {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .animate-spin-slow {
            animation: spin-slow 8s linear infinite;
        }

        /* Premium Sidebar Navbar Navigation */
        aside a {
            font-size: 0.9rem !important; /* Larger text size, about 14.4px */
            font-weight: 700 !important; /* Bold */
            padding: 0.75rem 1rem !important; /* Spacing */
            margin-bottom: 0.35rem !important;
            display: flex !important;
            align-items: center !important;
            gap: 0.85rem !important;
            border-radius: 0.75rem !important; /* Rounded corners */
            color: #334155 !important; /* Slate 700 */
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
        }
        aside a i {
            color: #b0841a !important; /* Gold icons in inactive state */
            font-size: 1.1rem !important; /* Larger icons for scanning */
            width: 1.5rem !important;
            text-align: center !important;
            transition: color 0.25s ease !important;
        }
        aside a:hover {
            background-color: #fafaf9 !important; /* Soft warm grey background */
            color: #b0841a !important; /* Hover text in gold */
        }
        aside a:hover i {
            color: #b0841a !important; /* Keep hover icon gold */
        }
        
        /* Active Link State */
        aside a.bg-sidebar-active {
            background: linear-gradient(135deg, #b0841a 0%, #8c6510 100%) !important;
            color: #ffffff !important;
            box-shadow: 0 4px 15px rgba(176, 132, 26, 0.3) !important;
            font-weight: 850 !important;
        }
        aside a.bg-sidebar-active i {
            color: #ffffff !important; /* Force white icon when active */
        }

        /* Sidebar Section Headers */
        aside .sidebar-header {
            font-size: 0.75rem !important; /* text-xs */
            font-weight: 850 !important;
            color: #94a3b8 !important; /* Slate-400 */
            letter-spacing: 0.075em !important;
            text-transform: uppercase !important;
            padding: 1rem 1rem 0.35rem 1rem !important;
        }

    </style>
</head>
<body class="antialiased selection:bg-[#b0841a] selection:text-white">

    <!-- ================= شريط أخبار الـ KPIs اللانهائي ================= -->
    <div class="ticker-wrap py-4 text-sm font-black">
        <div class="ticker-container">
            <div class="ticker">
                <div class="ticker__item">
                    <span class="text-gold-brand"><i class="fa-solid fa-square-poll-vertical animate-pulse me-1.5"></i> <span data-i18n="ticker-perf-label">الأداء العام لشركة رواحل:</span></span> 
                    <span data-i18n="ticker-perf-desc">معدل إنجاز قطاعات التشغيل</span> 
                    <span class="text-[#b0841a] font-black mx-1" id="ticker-total-perf">--</span> 
                    <span data-i18n="ticker-may">لشهر مايو.</span>
                </div>
                <div class="ticker__item">
                    <span class="text-gold-brand"><i class="fa-solid fa-chart-line me-1.5"></i> <span data-i18n="ticker-revenue-label">نمو الإيرادات:</span></span> 
                    <span data-i18n="ticker-revenue-desc">حققنا نسبة نمو بقيمة</span> 
                    <span class="text-emerald-700 font-black mx-1" id="ticker-rev-growth">@Model.TotalRevenue M ر.س</span> 
                </div>
                <div class="ticker__item">
                    <span class="text-gold-brand"><i class="fa-solid fa-money-bill-trend-up me-1.5"></i> <span data-i18n="ticker-ebitda-label">هامش EBITDA التشغيلي:</span></span> 
                    <span data-i18n="ticker-ebitda-desc">أداء مالي متزن ويسجل</span> 
                    <span class="text-emerald-700 font-black mx-1" id="ticker-ebitda">@Model.Ebitda%</span>.
                </div>
                <div class="ticker__item">
                    <span class="text-gold-brand"><i class="fa-solid fa-bus-simple me-1.5"></i> <span data-i18n="ticker-fleet-label">جاهزية الأسطول الحالية:</span></span> 
                    <span data-i18n="ticker-fleet-desc">جاهزية حافلات التشغيل ترتفع لـ</span> 
                    <span class="text-[#b0841a] font-black mx-1" id="ticker-fleet-ready">@Model.FleetReady%</span> 
                    <span data-i18n="ticker-fleet-total">(إجمالي 1,240 حافلة).</span>
                </div>
                <div class="ticker__item">
                    <span class="text-gold-brand"><i class="fa-solid fa-star-half-stroke me-1.5"></i> <span data-i18n="ticker-nps-label">رضا العملاء NPS:</span></span> 
                    <span data-i18n="ticker-nps-desc">نقاط رضا ضيوف الرحمن تسجل</span> 
                    <span class="text-[#b0841a] font-black mx-1" id="ticker-nps">@Model.Nps نقطة</span> 
                </div>
            </div>
            <!-- مكرر لدوران الأنباء بسلاسة -->
            <div class="ticker" aria-hidden="true">
                <div class="ticker__item">
                    <span class="text-gold-brand"><i class="fa-solid fa-square-poll-vertical animate-pulse me-1.5"></i> <span data-i18n="ticker-perf-label">الأداء العام لشركة رواحل:</span></span> 
                    <span data-i18n="ticker-perf-desc">معدل إنجاز قطاعات التشغيل</span> 
                    <span class="text-[#b0841a] font-black mx-1" id="ticker-total-perf-dup">--</span> 
                </div>
                <div class="ticker__item">
                    <span class="text-gold-brand"><i class="fa-solid fa-chart-line me-1.5"></i> <span data-i18n="ticker-revenue-label">نمو الإيرادات:</span></span> 
                    <span class="text-emerald-700 font-black mx-1" id="ticker-rev-growth-dup">@Model.TotalRevenue M ر.س</span>.
                </div>
            </div>
        </div>
    </div>

    <div class="flex min-h-screen">
        <!-- ================= القائمة الجانبية (Sidebar) ================= -->
        <aside class="w-72 bg-sidebar text-slate-700 p-5 flex flex-col justify-between hidden lg:flex border-e-2 border-[#b0841a]/40 shrink-0 shadow-sm">
            <div>
                <!-- الشعار المطور المعتمد لشركة رواحل -->
                <div onclick="showView('overview')" class="flex flex-col items-center text-center mt-2 mb-6 bg-white border border-[#b0841a]/30 p-4 rounded-xl shadow-xs cursor-pointer hover:opacity-95 transition-opacity">
                    <img src="https://www.rawahel.com.sa/wp-content/themes/tl4s-raoaa_rawahel/images/logo.png" alt="شركة رواحل المشاعر" class="w-24 h-auto object-contain mb-1 filter drop-shadow-sm">
                    <h2 class="text-slate-800 text-xs font-black tracking-wide mt-1" data-i18n="sidebar-logo-text">شركة رواحل المشاعر</h2>
                    <span class="text-[8px] text-[#b0841a] block tracking-wider font-bold mt-0.5">RAWAHEL AL MASHAER CO.</span>
                </div>

                <nav class="space-y-1.5">
                    <a href="javascript:void(0)" onclick="showView('overview')" id="lnk-overview" class="flex items-center gap-3 px-4 py-2.5 bg-sidebar-active rounded-xl text-xs font-black shadow-md transition-all">
                        <i class="fa-solid fa-table-columns text-base"></i>
                        <span data-i18n="nav-overview">الرئيسية والتحليل الموحد</span>
                    </a>
                    
                    <div class="sidebar-header" data-i18n="sidebar-business-areas">قطاعات الأعمال الحيوية</div>
                    
                    <a href="javascript:void(0)" onclick="showView('contracts')" id="lnk-contracts">
                        <i class="fa-solid fa-file-contract"></i>
                        <span data-i18n="nav-contracts">قطاع العقود والاتفاقيات</span>
                    </a>
                    
                    <a href="javascript:void(0)" onclick="showView('hajj')" id="lnk-hajj">
                        <i class="fa-solid fa-kaaba"></i>
                        <span data-i18n="nav-hajj">قطاع الحج والعمرة</span>
                    </a>
                    
                    <a href="javascript:void(0)" onclick="showView('leasing')" id="lnk-leasing">
                        <i class="fa-solid fa-key"></i>
                        <span data-i18n="nav-leasing">قطاع الإيجار والتشغيل</span>
                    </a>

                    <div class="sidebar-header" data-i18n="sidebar-company-depts">إدارات وأقسام الشركة</div>

                    <a href="javascript:void(0)" onclick="showView('departments')" id="lnk-departments">
                        <i class="fa-solid fa-layer-group"></i>
                        <span data-i18n="show-all-departments">عرض جميع الإدارات</span>
                    </a>
                </nav>
            </div>

            <div class="space-y-1 border-t border-slate-100 pt-3">
                @if (Model.IsSuperAdmin)
                {
                    <a href="/Users">
                        <i class="fa-solid fa-users-cog"></i>
                        <span>إدارة المستخدمين</span>
                    </a>
                }
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                {
                    <a href="/Settings">
                        <i class="fa-solid fa-gear"></i>
                        <span data-i18n="sidebar-settings">إعدادات المستهدفات</span>
                    </a>
                }
                <div class="text-[9px] text-slate-400 text-center pt-2 font-mono" data-i18n="sidebar-copyright">نظام رواحل القياسي المعتمد © 2026</div>
            </div>
        </aside>

        <!-- ================= المحتوى الرئيسي ================= -->
        <main class="flex-1 p-6 lg:p-10 xl:p-12 overflow-y-auto max-w-[1600px] mx-auto w-full">
            
            <!-- الهيدر العلوي -->
            <header class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8 bg-white p-5 rounded-2xl border border-[#b0841a]/20 shadow-xs relative overflow-hidden">
                <div class="text-right">
                    <h1 class="text-xl sm:text-2xl font-black text-slate-900 tracking-tight flex items-center gap-2">
                        <span class="w-2 h-6 bg-gradient-to-b from-[#b0841a] to-[#8c6510] rounded-full inline-block"></span>
                        <span id="header-main-title" class="bg-gradient-to-r from-slate-900 via-slate-800 to-[#b0841a] bg-clip-text text-transparent" data-i18n="header-title">نظام مراقبة الأداء لشركة رواحل</span>
                    </h1>
                    <p class="text-xs text-[#b0841a] mt-1.5 font-bold flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-ping"></span>
                        <span data-i18n="header-subtitle">لوحة تفاعلية حية متصلة بقاعدة البيانات ومطابقة لألوان الهوية الرسمية</span>
                    </p>
                </div>
                
                <div class="flex items-center gap-3 w-full sm:w-auto justify-end">
                    <!-- زر تبديل اللغة (Language Toggle) -->
                    <button id="langToggleBtn" onclick="toggleLanguage()" class="bg-slate-100 hover:bg-slate-200 text-[#b0841a] border border-[#b0841a]/30 px-4 py-2.5 rounded-xl text-xs font-black flex items-center gap-2 transition-all cursor-pointer">
                        <i class="fa-solid fa-globe text-[#b0841a]"></i>
                        <span id="langToggleText">English (EN)</span>
                    </button>

                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                    {
                        <a href="/Settings" class="bg-slate-100 hover:bg-slate-200 text-slate-800 border border-slate-200 px-4 py-2.5 rounded-xl text-xs font-black flex items-center gap-2 transition-all cursor-pointer shadow-xs">
                            <i class="fa-solid fa-sliders text-[#b0841a]"></i>
                            <span data-i18n="sidebar-settings">تعديل المستهدفات</span>
                        </a>
                    }

                    <!-- زر تسجيل الخروج -->
                    <form method="post" action="/Account/Logout" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="bg-slate-100 hover:bg-slate-200 text-rose-600 border border-slate-200 px-4 py-2.5 rounded-xl text-xs font-black flex items-center gap-2 transition-all cursor-pointer shadow-xs">
                            <i class="fa-solid fa-sign-out-alt"></i>
                            <span data-i18n="logout">خروج</span>
                        </button>
                    </form>

                    <!-- الملف الشخصي للمستخدِم -->
                    <div onclick="openProfileModal()" class="flex items-center gap-3 border-s border-slate-200 ps-4 cursor-pointer hover:opacity-85 transition-opacity">
                        <div class="text-start">
                            <div class="flex items-center gap-1.5 justify-start">
                                <i class="fa-solid fa-circle-info text-[10px] text-[#b0841a]"></i>
                                <h4 class="text-xs font-black text-slate-800">@Model.UserArabicDisplayName</h4>
