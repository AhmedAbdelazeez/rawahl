        };

        let mixedChart = null, flagsPieChart = null, drawerChartInstance = null;
        let activeKpiKey = null;

        // دالة فحص وتعيين الأعلام الملونة اللامعة والملفتة
        function assignFlagAndStyle(flagId, value, target, isInverse = false) {
            const el = document.getElementById(flagId);
            if (!el) return 'excellent';
            
            let achievementRatio = isInverse ? (target / (value || 0.1)) * 100 : (value / target) * 100;
            if(isInverse && value <= target) achievementRatio = 100;

            if (achievementRatio >= 95) {
                el.innerText = "🟢 ممتاز";
                el.className = "text-[9px] font-black px-2.5 py-0.5 rounded-full bg-emerald-500/10 text-emerald-500 border border-emerald-500/35 shadow-[0_0_10px_rgba(16,185,129,0.3)] animate-pulse";
                return 'excellent';
            } else if (achievementRatio >= 75) {
                el.innerText = "🟡 جيد";
                el.className = "text-[9px] font-black px-2.5 py-0.5 rounded-full bg-amber-500/10 text-amber-600 border border-amber-500/35 shadow-[0_0_10px_rgba(245,158,11,0.3)]";
                return 'good';
            } else {
                el.innerText = "🔴 ضعيف";
                el.className = "text-[9px] font-black px-2.5 py-0.5 rounded-full bg-red-500/10 text-red-500 border border-red-500/35 shadow-[0_0_10px_rgba(239,68,68,0.3)] animate-pulse";
                return 'bad';
            }
        }

        // دالة فتح نافذة الـ Drilldown والتعمق (centered modal popup)
        function openDrilldown(kpiKey) {
            activeKpiKey = kpiKey;
            
            // تهيئة المودال قبل إظهاره
            try {
                updateDrawerContent();
            } catch (e) {
                console.error("Error updating drawer content:", e);
            }
            
            const modal = document.getElementById('drilldownModal');
            const overlay = document.getElementById('modalOverlay');
            const box = document.getElementById('modalBox');
            
            if (modal && overlay && box) {
                modal.classList.remove('hidden');
                setTimeout(() => {
                    overlay.classList.remove('opacity-0');
                    box.classList.remove('scale-90', 'opacity-0');
                    box.classList.add('scale-100', 'opacity-100');
                }, 50);
            }
        }

        // إغلاق نافذة التعمق (centered modal popup)
        function closeDrilldown() {
            const modal = document.getElementById('drilldownModal');
            const overlay = document.getElementById('modalOverlay');
            const box = document.getElementById('modalBox');
            
            if (modal && overlay && box) {
                box.classList.remove('scale-100', 'opacity-100');
                box.classList.add('scale-90', 'opacity-0');
                overlay.classList.add('opacity-0');
                
                setTimeout(() => {
                    modal.classList.add('hidden');
                    activeKpiKey = null;
                }, 300);
            }
        }

        // تحديث محتويات نافذة التعمق بناء على الـ KPI الفعال
        function updateDrawerContent() {
            if (!activeKpiKey || !kpiSubKpis[activeKpiKey]) return;
            
            const kpiInfo = kpiSubKpis[activeKpiKey];
            const valEl = document.getElementById(`val-${activeKpiKey}`);
            const flagEl = document.getElementById(`flag-${activeKpiKey}`);
            
            const currentValStr = valEl ? valEl.innerText : "0%";
            
            // استخراج القيم العددية لحساب النسب الفرعية
            const currentValNum = parseFloat(currentValStr.replace(/[^0-9.]/g, '')) || 0;
            
            // 1. تعبئة النصوص الرئيسية بالنافذة المنبثقة
            const drawerTitleEl = document.getElementById('drawerTitle');
            if (drawerTitleEl) drawerTitleEl.innerHTML = `<span class="w-2.5 h-2.5 rounded-full bg-[#D4B795] animate-pulse"></span>` + kpiInfo.title;
            
            const drawerSubtitleEl = document.getElementById('drawerSubtitle');
            if (drawerSubtitleEl) drawerSubtitleEl.innerText = kpiInfo.subtitle;
            
            const drawerCurrentValEl = document.getElementById('drawerCurrentVal');
            if (drawerCurrentValEl) drawerCurrentValEl.innerText = currentValStr;
            
            const drawerNotesEl = document.getElementById('drawerNotes');
            if (drawerNotesEl) drawerNotesEl.innerText = kpiInfo.notes;
            
            // مطابقة المستهدف المعروض ديناميكياً
            let targetText = "0%";
            const targetVal = kpiTargets[activeKpiKey];
            if (activeKpiKey === 'rev-growth') targetText = `${targetVal}M ر.س (نمو ${Math.round((targetVal - 118.75) / 118.75 * 100)}%)`;
            else if (activeKpiKey === 'ebitda') targetText = `${targetVal}%`;
            else if (activeKpiKey === 'cashflow') targetText = `${targetVal}M`;
            else if (activeKpiKey === 'roa') targetText = `${targetVal}%`;
            else if (activeKpiKey === 'cust-ret') targetText = `${targetVal}%`;
            else if (activeKpiKey === 'nps') targetText = `${targetVal}`;
            else if (activeKpiKey === 'ops-plan') targetText = `${targetVal}%`;
            else if (activeKpiKey === 'fleet-ready') targetText = `${targetVal}%`;
            else if (activeKpiKey === 'fleet-util') targetText = `${targetVal}%`;
            else if (activeKpiKey === 'hr-ret') targetText = `${targetVal}%`;
            else if (activeKpiKey === 'it-autom') targetText = `${targetVal}%`;
            else if (activeKpiKey === 'hse-ltifr') targetText = `${targetVal}`;
            else if (activeKpiKey === 'hse-accidents') targetText = `${targetVal}`;
            else if (activeKpiKey === 'audit-comp') targetText = `${targetVal}%`;
            else if (activeKpiKey === 'strat-goals') targetText = `${targetVal}%`;
            else if (activeKpiKey === 'strat-init') targetText = `${targetVal}%`;
            
            const drawerTargetValEl = document.getElementById('drawerTargetVal');
            if (drawerTargetValEl) drawerTargetValEl.innerText = "المستهدف المطلوب: " + targetText;
            
            // تعيين العلم بالنافذة
            const statusEl = document.getElementById('drawerStatusFlag');
            if (statusEl && flagEl) {
                statusEl.innerText = flagEl.innerText;
                statusEl.className = flagEl.className + " text-[9px] font-bold px-3 py-1 rounded-full shadow-xs animate-none";
            }

            // 2. معالجة وحقن المؤشرات الفرعية التابعة Sub-KPIs
            const subKpisList = kpiInfo.subKpis(currentValNum);
            const subKpiContainer = document.getElementById('drawerSubKpis');
            if (subKpiContainer) {
                subKpiContainer.innerHTML = '';
                
                subKpisList.forEach(sub => {
                    let badgeClass = "bg-slate-100 text-slate-700";
                    let badgeIcon = "⚪";
                    if (sub.flag === 'excellent') {
                        badgeClass = "bg-emerald-500/10 text-emerald-500 border border-emerald-500/35 shadow-[0_0_8px_rgba(16,185,129,0.25)]";
                        badgeIcon = "🟢 ممتاز";
                    } else if (sub.flag === 'good') {
                        badgeClass = "bg-amber-500/10 text-amber-600 border border-amber-500/35 shadow-[0_0_8px_rgba(245,158,11,0.25)]";
                        badgeIcon = "🟡 جيد";
                    } else if (sub.flag === 'bad') {
                        badgeClass = "bg-red-500/10 text-red-500 border border-red-500/35 shadow-[0_0_8px_rgba(239,68,68,0.25)]";
                        badgeIcon = "🔴 ضعيف";
                    }
                    
                    const itemHtml = `
                        <div class="bg-[#1e293b]/50 p-3.5 rounded-xl border border-slate-800 flex items-center justify-between shadow-md hover:border-[#D4B795]/30 transition-all">
                            <div>
                                <span class="text-[10px] font-black text-slate-200 block">${sub.name}</span>
                                <span class="text-[9px] text-slate-400 font-bold block mt-0.5">المستهدف: ${sub.target}</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="text-xs font-black text-white font-mono">${sub.value}</span>
                                <span class="text-[8px] font-black px-2 py-0.5 rounded-full ${badgeClass}">${badgeIcon}</span>
                            </div>
                        </div>
                    `;
                    subKpiContainer.innerHTML += itemHtml;
                });
            }

            // 3. بناء وتحديث الرسم البياني الفرعي المخصص (Sub Chart.js Generator)
            if (typeof Chart !== 'undefined') {
                const canvasEl = document.getElementById('drawerChart');
                if (canvasEl) {
                    try {
                        if (drawerChartInstance) {
                            drawerChartInstance.destroy();
                        }
                        
                        const ctxDrawer = canvasEl.getContext('2d');
                        drawerChartInstance = new Chart(ctxDrawer, {
                            type: kpiInfo.chartType,
                            data: {
                                labels: kpiInfo.chartLabels,
                                datasets: [{
                                    label: kpiInfo.title,
                                    data: kpiInfo.chartData(currentValNum),
                                    backgroundColor: kpiInfo.chartType === 'doughnut' ? 
                                        ['#00bfa5', '#ffe0b2', '#ff5252', '#7c4dff'] : 'rgba(0, 191, 165, 0.2)',
                                    borderColor: '#00bfa5',
                                    borderWidth: 2.5,
                                    fill: true
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: { 
                                        display: kpiInfo.chartType === 'doughnut' || kpiInfo.chartType === 'polarArea',
                                        position: 'bottom',
                                        labels: { 
                                            color: '#e2e8f0',
                                            font: { family: 'Cairo', size: 9, weight: 'bold' } 
                                        } 
                                    }
                                },
                                scales: kpiInfo.chartType !== 'doughnut' && kpiInfo.chartType !== 'polarArea' && kpiInfo.chartType !== 'radar' ? {
                                    y: { 
                                        grid: { color: 'rgba(255, 255, 255, 0.08)' },
                                        ticks: {
                                            color: '#cbd5e1',
                                            font: { family: 'Cairo', size: 9, weight: 'bold' }
                                        }
                                    },
                                    x: { 
                                        grid: { color: 'rgba(255, 255, 255, 0.05)' },
                                        ticks: {
                                            color: '#cbd5e1',
                                            font: { family: 'Cairo', size: 9, weight: 'bold' }
                                        }
                                    }
                                } : (kpiInfo.chartType === 'radar' ? {
                                    r: {
                                        angleLines: { color: 'rgba(255, 255, 255, 0.15)' },
                                        grid: { color: 'rgba(255, 255, 255, 0.15)' },
                                        pointLabels: {
                                            color: '#cbd5e1',
                                            font: { family: 'Cairo', size: 8, weight: 'bold' }
                                        },
                                        ticks: {
                                            backdropColor: 'transparent',
                                            color: '#cbd5e1',
                                            font: { family: 'Cairo', size: 8 }
                                        }
                                    }
                                } : undefined)
                            }
                        });
                    } catch (e) {
                        console.error("Error creating drawerChart:", e);
                    }
                }
            }
        }

        // دالة مساعدة لتحديث نصوص الواجهة والتحقق الآمن
        function safeSetText(id, text) {
            const el = document.getElementById(id);
            if (el) el.innerText = text;
        }

        // دالة مساعدة لتحديث شريط التقدم والتحقق الآمن
        function safeSetWidth(id, widthPct) {
            const el = document.getElementById(id);
            if (el) el.style.width = widthPct + '%';
        }

        // توليد الأرقام ومطابقتها وعرض الأعلام وقيمها المزامنة
        function simulateKpiData(useActualData = false) {
            // 1. توليد القيم العشوائية للاختبار أو استخدام البيانات الفعلية من C#
            const revGrowthNum = useActualData ? @(Model.TotalRevenue / 118.75 * 100 - 100) : (Math.floor(Math.random() * 15) + 12);
            const ebitda = useActualData ? @Model.Ebitda : (Math.floor(Math.random() * 12) + 25);
            const cashflow = useActualData ? @Model.CashFlow : (Math.floor(Math.random() * 20) + 32);
            const roa = useActualData ? @Model.Roa : (Math.floor(Math.random() * 6) + 7);
            const custRet = useActualData ? @Model.CustRetention : (Math.floor(Math.random() * 16) + 75);
            const nps = useActualData ? @Model.Nps : (Math.floor(Math.random() * 25) + 40);
            const opsPlan = useActualData ? @Model.OpsPlan : (Math.floor(Math.random() * 12) + 84);
            const fleetReady = useActualData ? @Model.FleetReady : (Math.floor(Math.random() * 11) + 87);
            const fleetUtil = useActualData ? @Model.FleetUtil : (Math.floor(Math.random() * 15) + 75);
            const hrRet = useActualData ? @Model.HrRetention : (Math.floor(Math.random() * 10) + 84);
            const itAutom = useActualData ? @Model.ItAutomation : (Math.floor(Math.random() * 25) + 65);
            const ltifr = useActualData ? @Model.Ltifr : parseFloat((Math.random() * 1.8).toFixed(1));
            const accidents = useActualData ? @Model.Accidents : (Math.random() > 0.85 ? 1 : 0);
            const auditComp = useActualData ? @Model.AuditCompliance : (Math.floor(Math.random() * 10) + 88);
            const stratGoals = useActualData ? @Model.StrategicGoals : (Math.floor(Math.random() * 15) + 76);
            const stratInit = useActualData ? @Model.StrategicInitiatives : (Math.floor(Math.random() * 16) + 75);

            // حساب الإيراد الإجمالي الحقيقي المعادل بالنسبة المئوية للنمو
            const baseRevenue = 118.75; // المداخيل الأساسية
            const currentRevenue = parseFloat((baseRevenue * (1 + revGrowthNum / 100)).toFixed(1));

            // 2. حقن القيم داخل خلايا الـ HTML لتحديث الواجهة الفوري
            safeSetText('val-rev-growth', currentRevenue + 'M ر.س');
            safeSetText('target-rev-growth', 'المستهدف: 150M ر.س (نمو 25%)');
            safeSetText('val-ebitda', ebitda + '%');
            safeSetText('val-cashflow', cashflow + 'M');
            safeSetText('val-roa', roa + '%');
            safeSetText('val-cust-ret', custRet + '%');
            safeSetText('val-nps', nps);
            safeSetText('val-ops-plan', opsPlan + '%');
            safeSetText('val-fleet-ready', fleetReady + '%');
            safeSetText('val-fleet-util', fleetUtil + '%');
            safeSetText('val-hr-ret', hrRet + '%');
            safeSetText('val-it-autom', itAutom + '%');
            safeSetText('val-hse-ltifr', ltifr);
            safeSetText('val-hse-accidents', accidents);
            safeSetText('val-audit-comp', auditComp + '%');
            safeSetText('val-strat-goals', stratGoals + '%');
            safeSetText('val-strat-init', stratInit + '%');

            // تحديث أشرطة التقدم المرئية تحت كل مؤشر رئيسي
            safeSetWidth('bar-rev-growth', Math.min(currentRevenue / kpiTargets['rev-growth'] * 100, 100));
            safeSetWidth('bar-ebitda', Math.min(ebitda / kpiTargets['ebitda'] * 100, 100));
            safeSetWidth('bar-cashflow', Math.min(cashflow / kpiTargets['cashflow'] * 100, 100));
            safeSetWidth('bar-roa', Math.min(roa / kpiTargets['roa'] * 100, 100));
            safeSetWidth('bar-cust-ret', Math.min(custRet / kpiTargets['cust-ret'] * 100, 100));
            safeSetWidth('bar-nps', Math.min(nps / kpiTargets['nps'] * 100, 100));
            safeSetWidth('bar-ops-plan', Math.min(opsPlan / kpiTargets['ops-plan'] * 100, 100));
            safeSetWidth('bar-fleet-ready', Math.min(fleetReady / kpiTargets['fleet-ready'] * 100, 100));
            safeSetWidth('bar-fleet-util', Math.min(fleetUtil / kpiTargets['fleet-util'] * 100, 100));

            // تعيين ألوان شريط التقدم بناء على العلم (أحمر / برتقالي / أخضر)
            const updateBarColor = (barId, flagType) => {
                const el = document.getElementById(barId);
                if(!el) return;
                el.className = "h-full transition-all duration-500 rounded-full relative " + 
                    (flagType === 'excellent' ? 'bg-emerald-500' : (flagType === 'good' ? 'bg-amber-500' : 'bg-red-500'));
            };

            // 3. احتساب الأعلام وإعطاء النتيجة الإحصائية لمنطقة (الملخص العام) في الأعلى
            let flagCounter = { excellent: 0, good: 0, bad: 0 };

            // نحتسب العلم للإيرادات بناء على النسبة الفعلية
            flagCounter[assignFlagAndStyle('flag-rev-growth', currentRevenue, kpiTargets['rev-growth'])]++;
            flagCounter[assignFlagAndStyle('flag-ebitda', ebitda, kpiTargets['ebitda'])]++;
            flagCounter[assignFlagAndStyle('flag-cashflow', cashflow, kpiTargets['cashflow'])]++;
            flagCounter[assignFlagAndStyle('flag-roa', roa, kpiTargets['roa'])]++;
            flagCounter[assignFlagAndStyle('flag-cust-ret', custRet, kpiTargets['cust-ret'])]++;
            flagCounter[assignFlagAndStyle('flag-nps', nps, kpiTargets['nps'])]++;
            flagCounter[assignFlagAndStyle('flag-ops-plan', opsPlan, kpiTargets['ops-plan'])]++;
            flagCounter[assignFlagAndStyle('flag-fleet-ready', fleetReady, kpiTargets['fleet-ready'])]++;
            flagCounter[assignFlagAndStyle('flag-fleet-util', fleetUtil, kpiTargets['fleet-util'])]++;
            flagCounter[assignFlagAndStyle('flag-hr-ret', hrRet, kpiTargets['hr-ret'])]++;
            flagCounter[assignFlagAndStyle('flag-it-autom', itAutom, kpiTargets['it-autom'])]++;
            flagCounter[assignFlagAndStyle('flag-hse-ltifr', ltifr, kpiTargets['hse-ltifr'], true)]++; // مؤشر عكسي
            flagCounter[assignFlagAndStyle('flag-hse-accidents', accidents, kpiTargets['hse-accidents'], true)]++; // مؤشر عكسي
            flagCounter[assignFlagAndStyle('flag-audit-comp', auditComp, kpiTargets['audit-comp'])]++;
            flagCounter[assignFlagAndStyle('flag-strat-goals', stratGoals, kpiTargets['strat-goals'])]++;
            flagCounter[assignFlagAndStyle('flag-strat-init', stratInit, kpiTargets['strat-init'])]++;

            // تطبيق ألوان شريط التقدم بعد معرفة العلم الفردي
            updateBarColor('bar-rev-growth', assignFlagAndStyle('flag-rev-growth', currentRevenue, kpiTargets['rev-growth']));
            updateBarColor('bar-ebitda', assignFlagAndStyle('flag-ebitda', ebitda, kpiTargets['ebitda']));
            updateBarColor('bar-cashflow', assignFlagAndStyle('flag-cashflow', cashflow, kpiTargets['cashflow']));
            updateBarColor('bar-roa', assignFlagAndStyle('flag-roa', roa, kpiTargets['roa']));
            updateBarColor('bar-cust-ret', assignFlagAndStyle('flag-cust-ret', custRet, kpiTargets['cust-ret']));
            updateBarColor('bar-nps', assignFlagAndStyle('flag-nps', nps, kpiTargets['nps']));
            updateBarColor('bar-ops-plan', assignFlagAndStyle('flag-ops-plan', opsPlan, kpiTargets['ops-plan']));
            updateBarColor('bar-fleet-ready', assignFlagAndStyle('flag-fleet-ready', fleetReady, kpiTargets['fleet-ready']));
            updateBarColor('bar-fleet-util', assignFlagAndStyle('flag-fleet-util', fleetUtil, kpiTargets['fleet-util']));

            // عرض الأرقام المجمعة في كروت الملخص العلوي
            safeSetText('count-excellent', flagCounter.excellent);
            safeSetText('count-good', flagCounter.good);
            safeSetText('count-bad', flagCounter.bad);

            // الأداء العام
            const avgPerf = Math.round(
                ((currentRevenue/kpiTargets['rev-growth']) + (ebitda/kpiTargets['ebitda']) + (cashflow/kpiTargets['cashflow']) + (roa/kpiTargets['roa']) + (custRet/kpiTargets['cust-ret']) + 
                (nps/kpiTargets['nps']) + (opsPlan/kpiTargets['ops-plan']) + (fleetReady/kpiTargets['fleet-ready']) + (fleetUtil/kpiTargets['fleet-util']) + (hrRet/kpiTargets['hr-ret']) + 
                (itAutom/kpiTargets['it-autom']) + (auditComp/kpiTargets['audit-comp']) + (stratGoals/kpiTargets['strat-goals']) + (stratInit/kpiTargets['strat-init'])) / 14 * 100
            );
            const clampedPerf = Math.min(Math.max(avgPerf, 30), 100);
            
            safeSetText('radial-progress-val', clampedPerf + '%');
            const radialPath = document.getElementById('radial-progress-path');
            if (radialPath) radialPath.setAttribute('stroke-dasharray', `${clampedPerf}, 100`);

            // تحديث نصوص الشريط الإخباري
            safeSetText('ticker-total-perf', clampedPerf + '%');
            safeSetText('ticker-total-perf-dup', clampedPerf + '%');
            safeSetText('ticker-rev-growth', currentRevenue + 'M ر.س');
            safeSetText('ticker-rev-growth-dup', currentRevenue + 'M ر.س');
            safeSetText('ticker-ebitda', ebitda + '%');
            safeSetText('ticker-ebitda-dup', ebitda + '%');
            safeSetText('ticker-fleet-ready', fleetReady + '%');
            safeSetText('ticker-fleet-ready-dup', fleetReady + '%');
            safeSetText('ticker-nps', nps + ' نقطة');
            safeSetText('ticker-nps-dup', nps + ' نقطة');
            safeSetText('ticker-ops-plan', opsPlan + '%');
            safeSetText('ticker-ops-plan-dup', opsPlan + '%');

            // 4. تحديث الرسوم البيانية الكبرى
            if (typeof Chart !== 'undefined') {
                if (mixedChart) {
                    try {
                        mixedChart.data.datasets[0].data = [
                            currentRevenue / kpiTargets['rev-growth'] * 100,
                            ebitda,
                            custRet,
                            opsPlan,
                            fleetReady,
                            stratGoals
                        ];
                        mixedChart.data.datasets[1].data = [
                            100,
                            kpiTargets['ebitda'],
                            kpiTargets['cust-ret'],
                            kpiTargets['ops-plan'],
                            kpiTargets['fleet-ready'],
                            kpiTargets['strat-goals']
                        ];
                        mixedChart.update();
                    } catch (e) { console.error(e); }
                }

                if (flagsPieChart) {
                    try {
                        flagsPieChart.data.datasets[0].data = [flagCounter.excellent, flagCounter.good, flagCounter.bad];
                        flagsPieChart.update();
                    } catch (e) { console.error(e); }
                }
            }

            // 5. تحديث المودال النشط بالبيانات فورياً
            if (activeKpiKey) {
                try {
                    updateDrawerContent();
                } catch (e) { console.error(e); }
            }
        }

        // بناء وتجهيز مخططات الرسوم البيانية الكبرى عند التحميل
        document.addEventListener("DOMContentLoaded", function() {
            // 1. Bar Chart
            if (typeof Chart !== 'undefined') {
                try {
                    const ctxBar = document.getElementById('barChartActualTarget').getContext('2d');
                    
                    // Create linear gradients for a premium glow look
                    const actualGradient = ctxBar.createLinearGradient(0, 0, 0, 300);
                    actualGradient.addColorStop(0, '#00bfa5'); // bright neon teal
                    actualGradient.addColorStop(1, '#005f54'); // deep teal
                    
                    const targetGradient = ctxBar.createLinearGradient(0, 0, 0, 300);
                    targetGradient.addColorStop(0, '#ffe0b2'); // bright gold
                    targetGradient.addColorStop(1, '#664d30'); // deep bronze/gold
                    
                    mixedChart = new Chart(ctxBar, {
                        type: 'bar',
                        data: {
                            labels: ['إجمالي الإيرادات %', 'هامش EBITDA %', 'الاحتفاظ بالعملاء %', 'الخطة التشغيلية %', 'جاهزية الأسطول %', 'الأهداف الاستراتيجية %'],
                            datasets: [
                                { label: 'الأداء الفعلي الحالي (Actual)', data: [0, 0, 0, 0, 0, 0], backgroundColor: actualGradient, borderRadius: 6 },
                                { 
                                    label: 'المستهدف الأساسي (Target)', 
                                    data: [
                                        100, 
                                        kpiTargets['ebitda'], 
                                        kpiTargets['cust-ret'], 
                                        kpiTargets['ops-plan'], 
                                        kpiTargets['fleet-ready'], 
                                        kpiTargets['strat-goals']
                                    ], 
                                    backgroundColor: targetGradient, 
                                    borderRadius: 6 
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { 
                                legend: { 
                                    labels: { 
                                        color: '#e2e8f0',
                                        font: { family: 'Cairo', size: 10, weight: 'bold' } 
                                    } 
                                } 
                            },
                            scales: { 
                                y: { 
                                    beginAtZero: true, 
                                    max: 100,
                                    grid: { color: 'rgba(255, 255, 255, 0.08)' },
                                    ticks: {
                                        color: '#cbd5e1',
                                        font: { family: 'Cairo', size: 9, weight: 'bold' }
                                    }
                                }, 
                                x: { 
                                    grid: { color: 'rgba(255, 255, 255, 0.05)' },
                                    ticks: { 
                                        color: '#cbd5e1',
                                        font: { family: 'Cairo', size: 9, weight: 'bold' } 
                                    } 
                                } 
                            }
                        }
                    });
                } catch (e) {
                    console.error("Error creating mixedChart:", e);
                }

                // 2. Pie Chart
                try {
                    const ctxPie = document.getElementById('doughnutFlagsChart').getContext('2d');
                    flagsPieChart = new Chart(ctxPie, {
                        type: 'doughnut',
                        data: {
                            labels: ['ممتاز 🟢', 'جيد 🟡', 'ضعيف 🔴'],
                            datasets: [{ data: [0, 0, 0], backgroundColor: ['#10b981', '#f59e0b', '#ef4444'], borderWidth: 1, borderColor: '#0f172a' }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { 
                                legend: { 
                                    position: 'bottom', 
                                    labels: { 
                                        color: '#e2e8f0',
                                        font: { family: 'Cairo', size: 9, weight: 'bold' } 
                                    } 
                                } 
                            }
                        }
                    });
                } catch (e) {
                    console.error("Error creating flagsPieChart:", e);
                }
            }

            // 3. تعبئة البيانات الافتراضية باستخدام قيم الـ Razor المرفوعة من السيرفر مباشرة
            try {
                simulateKpiData(true); 
            } catch (e) {
                console.error("Error running initial simulateKpiData:", e);
            }
        });

        // دوال فتح وإغلاق نافذة الملف الشخصي لـ CEO
        function openProfileModal() {
            const modal = document.getElementById('profileModal');
            const overlay = document.getElementById('profileModalOverlay');
            const box = document.getElementById('profileModalBox');
            
            if (modal && overlay && box) {
                modal.classList.remove('hidden');
                setTimeout(() => {
                    overlay.classList.remove('opacity-0');
                    box.classList.remove('scale-90', 'opacity-0');
                    box.classList.add('scale-100', 'opacity-100');
                }, 50);
            }
        }

        function closeProfileModal() {
            const modal = document.getElementById('profileModal');
            const overlay = document.getElementById('profileModalOverlay');
            const box = document.getElementById('profileModalBox');
            
            if (modal && overlay && box) {
                box.classList.remove('scale-100', 'opacity-100');
                box.classList.add('scale-90', 'opacity-0');
                overlay.classList.add('opacity-0');
                
                setTimeout(() => {
                    modal.classList.add('hidden');
                }, 300);
            }
        }
    </script>
</body>
</html>
