            'cashflow': {
                title: 'التدفق النقدي التشغيلي',
                subtitle: 'مراقبة السيولة النقدية والمقبوضات',
                notes: 'أولوية قصوى لتقليص فترات الذمم المدينة من وكلاء السياحة الخارجيين لتسريع دورة النقد في حسابات الشركة.',
                chartType: 'line',
                subKpis: (val) => [
                    { name: 'فترة تحصيل الذمم المدينة (أيام)', value: '42 يوم', target: '30 يوم', flag: 'bad' },
                    { name: 'التدفقات النقدية الداخلة للمحفظة', value: val + 'M ر.س', target: '50M ر.س', flag: val >= 40 ? 'good' : 'bad' }
