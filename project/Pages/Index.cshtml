@page
@model IndexModel
@{
    Layout = null;
    ViewData["Title"] = "لوحة المؤشرات الذكية - شركة رواحل المشاعر";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <!-- Tailwind CSS للتنسيق العصري والمودرن -->
    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@4"></script>
    <!-- Google Fonts - Cairo الخط العربي المعتمد احترافياً -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet">
    <!-- FontAwesome للأيقونات -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Chart.js للرسوم البيانية المتقدمة والأعمدة والمخطط الدائري -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- AOS Library للأنيميشن الاحترافي -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <style>
        body {
            font-family: 'Cairo', sans-serif;
            background-image: linear-gradient(rgba(9, 13, 22, 0.94), rgba(9, 13, 22, 0.94)), url('https://www.rawahel.com.sa/wp-content/themes/tl4s-raoaa_rawahel/images/slider10.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
            color: #f1f5f9;
        }

        .bg-sidebar { background-color: #0c0f17; }
        .bg-sidebar-active { 
            background: linear-gradient(135deg, #D4B795 0%, #B08E66 100%); 
            color: #111827 !important; 
            box-shadow: 0 4px 20px rgba(212, 183, 149, 0.4); 
        }
        
        .text-teal-brand { color: #00bfa5; filter: drop-shadow(0 2px 8px rgba(0, 191, 165, 0.35)); }
        .bg-teal-brand { background-color: #009688; box-shadow: 0 4px 15px rgba(0, 150, 136, 0.4); }
        .text-gold-brand { color: #D4B795; text-shadow: 0 2px 6px rgba(212, 183, 149, 0.25); }

        /* glassmorphism components with glowing effects */
        .glass-card {
            background-color: rgba(17, 24, 39, 0.72);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(212, 183, 149, 0.18);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.42);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            color: #f8fafc;
        }
        .glass-card:hover {
            transform: translateY(-5px) scale(1.02);
            border-color: rgba(0, 191, 165, 0.65);
            box-shadow: 0 15px 35px rgba(0, 191, 165, 0.22), 0 0 20px rgba(0, 191, 165, 0.12);
        }
        
        .bg-amber-light-card { 
            background-color: rgba(28, 25, 23, 0.78); 
            backdrop-filter: blur(16px);
            border: 1px solid rgba(212, 183, 149, 0.45); 
            box-shadow: 0 8px 32px 0 rgba(212, 183, 149, 0.15);
            color: #f8fafc;
        }

        /* ticker animations */
        .ticker-wrap {
            width: 100%;
            overflow: hidden;
            background: #090d16;
            border-bottom: 2px solid rgba(212, 183, 149, 0.45);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.45);
            direction: ltr !important; 
        }
        .ticker-container {
            display: flex;
            width: max-content;
            animation: ticker-loop 35s linear infinite;
        }
        .ticker {
            display: flex;
            white-space: nowrap;
            direction: rtl !important; 
        }
        .ticker__item {
            display: inline-flex;
            align-items: center;
            padding: 0 3rem; 
        }
        @@keyframes ticker-loop {
            0% { transform: translate3d(0, 0, 0); }
            100% { transform: translate3d(-50%, 0, 0); }
        }
        .ticker-wrap:hover .ticker-container {
            animation-play-state: paused;
        }

        /* progress bar metallic shine */
        @@keyframes shined {
            0% { background-position: -200px 0; }
            100% { background-position: 200px 0; }
        }
        .progress-shine-overlay {
            background-image: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.45) 50%, rgba(255,255,255,0) 100%);
            background-size: 200px 100%;
            animation: shined 3s infinite linear;
        }

        /* custom scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(15, 23, 42, 0.8);
        }
        ::-webkit-scrollbar-thumb {
            background: #D4B795;
            border-radius: 3px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #00bfa5;
        }

        /* glowing LED indicators */
        @@keyframes pulse-glow-teal {
            0%, 100% { box-shadow: 0 0 6px rgba(16, 185, 129, 0.35); }
            50% { box-shadow: 0 0 16px rgba(16, 185, 129, 0.65); }
        }
        @@keyframes pulse-glow-red {
            0%, 100% { box-shadow: 0 0 6px rgba(239, 68, 68, 0.35); }
            50% { box-shadow: 0 0 16px rgba(239, 68, 68, 0.65); }
        }
        .glow-pulse-teal {
            animation: pulse-glow-teal 2.2s infinite ease-in-out;
        }
        .glow-pulse-red {
            animation: pulse-glow-red 2.2s infinite ease-in-out;
        }

        @@keyframes spin-slow {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .animate-spin-slow {
            animation: spin-slow 8s linear infinite;
        }
    </style>
</head>
<body class="text-slate-950 antialiased selection:bg-[#009688] selection:text-white">

    <!-- ================= شريط أخبار الـ KPIs اللانهائي الحقيقي ================= -->
    <div class="ticker-wrap py-3.5 text-white text-xs font-bold">
        <div class="ticker-container">
            <div class="ticker">
                <div class="ticker__item"><span class="text-gold-brand"><i class="fa-solid fa-square-poll-vertical animate-pulse ml-1.5"></i> الأداء العام لشركة رواحل:</span> معدل إنجاز جميع القطاعات يسجل <span class="text-[#009688] font-black" id="ticker-total-perf">@Model.StrategicGoals%</span> لشهر مايو.</div>
                <div class="ticker__item"><span class="text-gold-brand"><i class="fa-solid fa-chart-line ml-1.5"></i> نمو الإيرادات:</span> حققنا نسبة نمو <span class="text-emerald-400 font-black" id="ticker-rev-growth">@Model.TotalRevenue M ر.س</span> من أصل 150M ر.س.</div>
                <div class="ticker__item"><span class="text-gold-brand"><i class="fa-solid fa-money-bill-trend-up ml-1.5"></i> هامش EBITDA التشغيلي:</span> أداء مالي متزن ويسجل <span class="text-emerald-400 font-black" id="ticker-ebitda">@Model.Ebitda%</span>.</div>
                <div class="ticker__item"><span class="text-gold-brand"><i class="fa-solid fa-bus-simple ml-1.5"></i> جاهزية الأسطول الحالية:</span> جاهزية حافلات التشغيل ترتفع لـ <span class="text-[#009688] font-black" id="ticker-fleet-ready">@Model.FleetReady%</span> (إجمالي 1,240 حافلة).</div>
                <div class="ticker__item"><span class="text-gold-brand"><i class="fa-solid fa-star-half-stroke ml-1.5"></i> رضا العملاء NPS:</span> نقاط قياس رضا ضيوف الرحمن تسجل <span class="text-[#009688] font-black" id="ticker-nps">@Model.Nps نقطة</span> بزيادة مستمرة.</div>
                <div class="ticker__item"><span class="text-gold-brand"><i class="fa-solid fa-clock-rotate-left ml-1.5"></i> الالتزام بالخطة التشغيلية:</span> نسبة الالتزام بجدول رحلات النقل والتوصيل بلغت <span class="text-emerald-400 font-black" id="ticker-ops-plan">@Model.OpsPlan%</span>.</div>
            </div>
            <div class="ticker" aria-hidden="true">
                <div class="ticker__item"><span class="text-gold-brand"><i class="fa-solid fa-square-poll-vertical animate-pulse ml-1.5"></i> الأداء العام لشركة رواحل:</span> معدل إنجاز جميع القطاعات يسجل <span class="text-[#009688] font-black" id="ticker-total-perf-dup">@Model.StrategicGoals%</span> لشهر مايو.</div>
                <div class="ticker__item"><span class="text-gold-brand"><i class="fa-solid fa-chart-line ml-1.5"></i> نمو الإيرادات:</span> حققنا نسبة نمو <span class="text-emerald-400 font-black" id="ticker-rev-growth-dup">@Model.TotalRevenue M ر.س</span>.</div>
                <div class="ticker__item"><span class="text-gold-brand"><i class="fa-solid fa-money-bill-trend-up ml-1.5"></i> هامش EBITDA التشغيلي:</span> أداء مالي متزن ويسجل <span class="text-emerald-400 font-black" id="ticker-ebitda-dup">@Model.Ebitda%</span>.</div>
                <div class="ticker__item"><span class="text-gold-brand"><i class="fa-solid fa-bus-simple ml-1.5"></i> جاهزية الأسطول الحالية:</span> جاهزية حافلات التشغيل ترتفع لـ <span class="text-[#009688] font-black" id="ticker-fleet-ready-dup">@Model.FleetReady%</span>.</div>
                <div class="ticker__item"><span class="text-gold-brand"><i class="fa-solid fa-star-half-stroke ml-1.5"></i> رضا العملاء NPS:</span> نقاط قياس رضا ضيوف الرحمن تسجل <span class="text-[#009688] font-black" id="ticker-nps-dup">@Model.Nps نقطة</span>.</div>
                <div class="ticker__item"><span class="text-gold-brand"><i class="fa-solid fa-clock-rotate-left ml-1.5"></i> الالتزام بالخطة التشغيلية:</span> نسبة الالتزام بجدول رحلات النقل والتوصيل بلغت <span class="text-emerald-400 font-black" id="ticker-ops-plan-dup">@Model.OpsPlan%</span>.</div>
            </div>
        </div>
    </div>

    <div class="flex min-h-screen">
        <!-- ================= القائمة الجانبية (Sidebar) ================= -->
        <aside class="w-72 bg-sidebar text-neutral-400 p-5 flex flex-col justify-between hidden lg:flex border-l-2 border-[#D4B795]/50 shrink-0">
            <div>
                <!-- الشعار المطور المعتمد لشركة رواحل -->
                <div class="flex flex-col items-center text-center mt-2 mb-6 bg-black/50 p-4 rounded-xl border border-neutral-800 shadow-inner">
                    <img src="https://www.rawahel.com.sa/wp-content/themes/tl4s-raoaa_rawahel/images/logo.png" alt="شركة رواحل المشاعر" class="w-24 h-auto object-contain mb-1 filter drop-shadow-md">
                    <h2 class="text-white text-xs font-black tracking-wide mt-1">شركة رواحل المشاعر</h2>
                    <span class="text-[8px] text-[#D4B795] block tracking-wider font-bold mt-0.5">RAWAHEL AL MASHAER CO.</span>
                </div>

                <nav class="space-y-1">
                    <a href="#general-read" class="flex items-center justify-between px-4 py-2.5 bg-sidebar-active rounded-xl text-xs font-black shadow-md transition-all">
                        <div class="flex items-center gap-3">
                            <i class="fa-solid fa-table-columns text-base"></i>
                            <span>لوحة المعلومات والأعلام</span>
                        </div>
                    </a>
                    
                    <a href="#finance-group" class="flex items-center gap-3 px-4 py-2 text-neutral-300 hover:text-white hover:bg-neutral-900 rounded-xl text-xs font-bold transition-all">
                        <i class="fa-solid fa-wallet text-[#009688] text-sm w-5"></i>
                        <span>الإدارة المالية</span>
                    </a>
                    
                    <a href="#commercial-group" class="flex items-center gap-3 px-4 py-2 text-neutral-300 hover:text-white hover:bg-neutral-900 rounded-xl text-xs font-bold transition-all">
                        <i class="fa-solid fa-chart-line text-[#009688] text-sm w-5"></i>
                        <span>الإدارة التجارية</span>
                    </a>
                    
                    <a href="#ops-fleet-group" class="flex items-center gap-3 px-4 py-2 text-neutral-300 hover:text-white hover:bg-neutral-900 rounded-xl text-xs font-bold transition-all">
                        <i class="fa-solid fa-bus text-[#009688] text-sm w-5"></i>
                        <span>العمليات والأسطول</span>
                    </a>

                    <a href="#support-group" class="flex items-center gap-3 px-4 py-2 text-neutral-300 hover:text-white hover:bg-neutral-900 rounded-xl text-xs font-bold transition-all">
                        <i class="fa-solid fa-handshake-angle text-[#009688] text-sm w-5"></i>
                        <span>الإدارات المساندة و HSE</span>
                    </a>
                </nav>
            </div>

            <div class="space-y-1 border-t border-neutral-900 pt-3">
                <a href="#" class="flex items-center gap-3 px-4 py-2 text-xs text-neutral-400 hover:text-white transition-all">
                    <i class="fa-regular fa-bell text-base w-5"></i>
                    <span>الإشعارات الفورية</span>
                </a>
                <a href="/Settings" class="flex items-center gap-3 px-4 py-2 text-xs text-neutral-400 hover:text-white transition-all">
                    <i class="fa-solid fa-gear text-base w-5"></i>
                    <span>إعدادات النظام</span>
                </a>
                <div class="text-[9px] text-neutral-600 text-center pt-2 font-mono">نظام رواحل القياسي المعتمد © 2026</div>
            </div>
        </aside>

        <!-- ================= المحتوى الرئيسي للملف المطور ================= -->
        <main class="flex-1 p-6 lg:p-8 overflow-y-auto max-w-7xl mx-auto w-full">
            
            <!-- الهيدر العلوي المطور بالكامل -->
            <header class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8 bg-slate-900/60 backdrop-blur-md p-5 rounded-2xl border border-[#D4B795]/20 shadow-2xl relative overflow-hidden">
                <!-- شريط خلفي مضيء للديكور -->
                <div class="absolute -right-20 -top-20 w-48 h-48 bg-[#009688]/10 rounded-full blur-3xl"></div>
                <div class="absolute -left-20 -bottom-20 w-48 h-48 bg-[#D4B795]/10 rounded-full blur-3xl"></div>

                <div class="relative z-10">
                    <h1 class="text-xl sm:text-2xl font-black text-white tracking-tight flex items-center gap-2">
                        <span class="w-2 h-6 bg-gradient-to-b from-[#009688] to-[#D4B795] rounded-full inline-block"></span>
                        <span class="bg-gradient-to-r from-white via-slate-200 to-[#D4B795] bg-clip-text text-transparent">نظام مراقبة الأداء بالأعلام والمطابقة الذكية</span>
                    </h1>
                    <p class="text-xs text-[#D4B795] mt-1.5 font-bold flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-ping"></span>
                        لوحة تفاعلية حية متصلة بقاعدة البيانات ومطابقة بالـ PageModel (C# Backend)
                    </p>
                </div>
                
                <div class="flex items-center gap-4 w-full sm:w-auto justify-end relative z-10">
                    <button onclick="simulateKpiData()" class="bg-gradient-to-r from-[#009688] to-[#007b70] hover:from-[#007b70] hover:to-[#005f56] text-white px-5 py-2.5 rounded-xl text-xs font-black flex items-center gap-2 shadow-lg shadow-[#009688]/20 hover:shadow-[#009688]/40 transition-all active:scale-95 cursor-pointer border border-[#009688]/30">
                        <i class="fa-solid fa-arrows-rotate animate-spin-slow"></i>
                        <span>تحديث وفحص الأعلام</span>
                    </button>

                    <!-- الملف الشخصي للمدير غسان عراقي (يمكن النقر عليه لفتح المودال المنبثق) -->
                    <div onclick="openProfileModal()" class="flex items-center gap-3 border-r border-slate-700/80 pr-4 cursor-pointer hover:opacity-80 transition-opacity">
                        <div class="text-left sm:text-right">
                            <div class="flex items-center gap-1.5 justify-end">
                                <i class="fa-solid fa-circle-info text-[10px] text-[#D4B795]"></i>
                                <h4 class="text-xs font-black text-slate-100">غسان عراقي</h4>
                            </div>
                            <span class="text-[9px] bg-gradient-to-r from-[#D4B795]/20 to-[#B08E66]/20 border border-[#D4B795]/30 text-[#D4B795] px-2.5 py-0.5 rounded-md font-black mt-1 inline-block">المدير العام (CEO)</span>
                        </div>
                        <div class="w-10 h-10 rounded-full border-2 border-[#D4B795] shadow-lg shadow-[#D4B795]/20 overflow-hidden bg-[#0c101b] flex items-center justify-center text-[#D4B795] font-black text-xs transition-transform hover:scale-105 active:scale-95">غ ع</div>
                    </div>
                </div>
            </header>

            <!-- ================= أولاً: الخلاصة والتحليل العلوي بالأعلام ================= -->
            <section id="general-read" class="mb-8" data-aos="fade-up">
                <div class="bg-gradient-to-r from-[#0d1321] via-[#162035] to-[#0d1321] rounded-3xl p-6 text-white shadow-2xl mb-6 border border-[#D4B795]/30 relative overflow-hidden">
                    <div class="absolute -right-24 -top-24 w-64 h-64 bg-[#009688]/5 rounded-full blur-3xl"></div>
                    
                    <div class="flex flex-col lg:flex-row justify-between items-center gap-6 relative z-10">
                        <div class="space-y-2 flex-1 text-right">
                            <span class="bg-[#009688]/20 text-[#00bfa5] text-[10px] px-3.5 py-1 rounded-full font-bold border border-[#009688]/30">نظرة عامة على الأداء الموحد</span>
                            <h2 class="text-xl font-black mt-2 text-white">مصفوفة إحصاء الأعلام لجميع مؤشرات شركة رواحل</h2>
                            <p class="text-slate-400 text-xs leading-relaxed font-semibold">اضغط على أي بطاقة مؤشر في الأسفل للتعمق وعرض تفاصيله ورسمه البياني الخاص بشكل فوري.</p>
                        </div>
                        
                        <!-- عدادات المؤشرات بتصميم LED راقي ومضيء -->
                        <div class="flex flex-wrap gap-3 bg-black/45 p-4 rounded-2xl border border-slate-700/40 justify-center">
                            <div class="text-center px-4">
                                <span class="block text-2xl font-black text-slate-100" id="count-total">16</span>
                                <span class="text-[9px] text-[#D4B795] font-black">إجمالي المؤشرات</span>
                            </div>
                            <div class="w-[1px] h-10 bg-slate-800"></div>
                            
                            <div class="text-center px-4 flex flex-col items-center">
                                <span class="flex items-center justify-center w-10 h-10 rounded-full bg-emerald-500/10 text-emerald-400 text-xl font-black border border-emerald-500/30 glow-pulse-teal" id="count-excellent">0</span>
                                <span class="text-[9px] text-slate-300 font-bold mt-1">ممتاز 🟢</span>
                            </div>
                            <div class="w-[1px] h-10 bg-slate-800"></div>
                            
                            <div class="text-center px-4 flex flex-col items-center">
                                <span class="flex items-center justify-center w-10 h-10 rounded-full bg-amber-500/10 text-amber-400 text-xl font-black border border-amber-500/30" id="count-good">0</span>
                                <span class="text-[9px] text-slate-300 font-bold mt-1">جيد 🟡</span>
                            </div>
                            <div class="w-[1px] h-10 bg-slate-800"></div>
                            
                            <div class="text-center px-4 flex flex-col items-center">
                                <span class="flex items-center justify-center w-10 h-10 rounded-full bg-red-500/10 text-red-400 text-xl font-black border border-red-500/30 glow-pulse-red" id="count-bad">0</span>
                                <span class="text-[9px] text-slate-300 font-bold mt-1">ضعيف 🔴</span>
                            </div>
                        </div>

                        <!-- المؤشر الدائري للأداء العام -->
                        <div class="relative w-24 h-24 flex items-center justify-center shrink-0 bg-slate-900/40 rounded-full p-1 border border-slate-700/30 shadow-inner">
                            <svg class="w-full h-full transform -rotate-90" viewBox="0 0 36 36">
                                <path class="text-slate-800/80" stroke-width="3" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                <path id="radial-progress-path" class="text-[#009688] drop-shadow-[0_0_8px_rgba(0,150,136,0.7)]" stroke-dasharray="76, 100" stroke-width="3.2" stroke-linecap="round" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                            </svg>
                            <div class="absolute flex flex-col items-center justify-center">
                                <span class="text-xl font-black text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]" id="radial-progress-val">76%</span>
                                <span class="text-[7px] text-[#D4B795] font-bold">متوسط الأداء</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- مساحة الرسوم البيانية الكبرى -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8" data-aos="fade-up">
                    <div class="glass-card p-5 rounded-2xl lg:col-span-2">
                        <h3 class="text-xs font-bold text-slate-200 mb-4"><i class="fa-solid fa-chart-bar text-[#00bfa5] ml-2"></i>تحليل ومقارنة الأداء الفعلي بالمستهدف الأساسي</h3>
                        <div class="h-64"><canvas id="barChartActualTarget"></canvas></div>
                    </div>
                    <div class="bg-amber-light-card p-5 rounded-2xl flex flex-col justify-between shadow-md">
                        <h3 class="text-xs font-bold text-slate-200 mb-2"><i class="fa-solid fa-flag text-[#D4B795] ml-2"></i>توزيع مؤشرات التقييم الحالية (الأعلام)</h3>
                        <div class="h-48 flex items-center justify-center"><canvas id="doughnutFlagsChart"></canvas></div>
                    </div>
                </div>
            </section>

            <!-- ================= ثانياً: مجموعات بطاقات الأداء التفصيلية ================= -->
            
            <!-- مجموعة 1: الإدارة المالية -->
            <section id="finance-group" class="mb-8" data-aos="fade-up">
                <div class="flex items-center gap-2 mb-4 border-b border-slate-800/60 pb-2">
