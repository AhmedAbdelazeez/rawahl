@page
@model project.Pages.Account.AccessDeniedModel
@{
    Layout = null;
    ViewData["Title"] = "وصول غير مصرح به - شركة رواحل المشاعر";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <!-- Tailwind CSS v4 -->
    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@4"></script>
    <!-- Google Fonts - Tajawal -->
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;850;900&display=swap" rel="stylesheet">
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            font-family: 'Tajawal', sans-serif;
            background-image: linear-gradient(rgba(15, 23, 42, 0.75), rgba(15, 23, 42, 0.85)), url('https://www.rawahel.com.sa/wp-content/themes/tl4s-raoaa_rawahel/images/slider10.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-md bg-white/95 backdrop-blur-md rounded-2xl shadow-2xl border border-white/20 overflow-hidden text-center p-8 transition-all duration-300">
        <div class="inline-block p-4 bg-amber-50 rounded-full text-amber-500 mb-4 animate-bounce">
            <i class="fas fa-exclamation-triangle text-4xl"></i>
        </div>
        
        <h2 class="text-2xl font-bold text-slate-800">وصول غير مصرح به!</h2>
        <p class="text-slate-600 mt-3 text-sm leading-relaxed">
            عذراً، الحساب الحالي لا يملك الصلاحيات الكافية للوصول إلى هذه الصفحة. يرجى التأكد من صلاحيات حسابك أو مراجعة مسؤول النظام.
        </p>

        <div class="mt-8 space-y-3">
            <a href="/" class="block w-full py-3 px-4 bg-gradient-to-l from-[#b0841a] to-[#8c6510] text-white font-bold rounded-xl shadow-lg hover:shadow-xl hover:from-[#c2962b] hover:to-[#9e761d] transition duration-150">
                <i class="fas fa-home ml-2"></i> العودة للرئيسية
            </a>
            
            <a href="/Account/Login" class="block w-full py-3 px-4 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold rounded-xl transition duration-150">
                <i class="fas fa-user-circle ml-2"></i> تسجيل الدخول بحساب آخر
            </a>
        </div>

        <div class="mt-8 pt-4 border-t border-slate-100">
            <span class="text-xs text-slate-400">شركة رواحل المشاعر لخدمات الحجاج والمعتمرين</span>
        </div>
    </div>
</body>
</html>
